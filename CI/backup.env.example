# /etc/mssql-backup/backup.env   — root:root, chmod 600. NEVER commit real values.
# deploy-backup.sh writes this file for you from CI/deploy-config.sh; this copy
# is just a reference for what each value means.

# --- local SQL Server (Docker) ---
MSSQL_CONTAINER=mssql
MSSQL_SA_PASSWORD=                        # = MSSQL_SA_PASSWORD from CI/deploy-config.sh
SQLCMD=/opt/mssql-tools18/bin/sqlcmd      # match the path your CI/db-*.sh scripts use
SQLCMD_FLAGS=-C                           # -C trusts the server cert (2022 image)

# --- Azure Blob Storage (private container) ---
AZ_ACCOUNT=yourstorageacct                # storage account name only (no .blob.core...)
AZ_CONTAINER=db-backups                   # private container name
AZ_SAS=?sv=2024-11-04&sp=racwl&se=...&sig=...   # container SAS, MUST start with '?'

# --- retention (bounded; storage never grows) ---
# Daily is always 7 (one slot per weekday). These set weekly/monthly depth.
# For literally "one weekly + one monthly", set both to 1.
WEEKLY_SLOTS=4                            # keep last 4 weekly backups
MONTHLY_SLOTS=12                          # keep last 12 monthly backups

# --- options ---
INCLUDE_SYSTEM_DBS=false                  # true also backs up master/model/msdb
COMPRESSION=false                         # MUST stay false on SQL Server Express
VERIFY=true                               # RESTORE VERIFYONLY each backup before upload
