@model DirectoryManager.Web.Models.AffiliateCommissionPaid.AffiliateCommissionEarnedEditViewModel

<fieldset>
    <p>
        <label asp-for="DirectoryEntryId"></label><br />
        <select asp-for="DirectoryEntryId" asp-items="Model.DirectoryEntries">
            <option value="">— Select entry —</option>
        </select>
        <span asp-validation-for="DirectoryEntryId" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="CommissionDate"></label><br />
        <input asp-for="CommissionDate" type="datetime-local"
               value="@Model.CommissionDate.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="CommissionDate" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="UsdValue"></label><br />
        <input asp-for="UsdValue" type="number" step="0.01" min="0" />
        <span asp-validation-for="UsdValue" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="PaymentCurrency"></label><br />
        <select asp-for="PaymentCurrency" asp-items="Model.CurrencyOptions"></select>
        <span asp-validation-for="PaymentCurrency" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="PaymentCurrencyAmount"></label><br />
        <input asp-for="PaymentCurrencyAmount" type="number" step="0.0000000000001" min="0" />
        <span asp-validation-for="PaymentCurrencyAmount" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="TransactionId"></label><br />
        <input asp-for="TransactionId" maxlength="255" style="width:30em;" />
        <span asp-validation-for="TransactionId" class="text-danger"></span>
    </p>

    <p>
        <label asp-for="Note"></label><br />
        <textarea asp-for="Note" rows="3" cols="60" maxlength="1000"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </p>
</fieldset>