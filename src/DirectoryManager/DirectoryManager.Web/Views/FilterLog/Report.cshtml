@model DirectoryManager.Web.Models.FilterLogReportViewModel

@{
    ViewData["Title"] = "Filter Activity Report";
    Layout = "_CenteredLayout";
    Func<DateTime, string> iso = dt => dt.ToString("o");
}

@functions {
    string Fmt(double pct) => pct.ToString("0.00") + "%";
}

@section PageContent {
    <h1>@ViewData["Title"]</h1>
    @await Html.PartialAsync("_AdminMenu")

    <p>
        Quick Filter:
        <a asp-action="Report" asp-route-start="@iso(DateTime.UtcNow.AddHours(-24))" asp-route-end="@iso(DateTime.UtcNow)">Last 24 Hours</a> |
        <a asp-action="Report" asp-route-start="@iso(DateTime.UtcNow.Date)" asp-route-end="@iso(DateTime.UtcNow)">Today (UTC)</a> |
        <a asp-action="Report" asp-route-start="@iso(DateTime.UtcNow.AddDays(-7))" asp-route-end="@iso(DateTime.UtcNow)">Last 7 Days</a> |
        <a asp-action="Report" asp-route-start="@iso(DateTime.UtcNow.AddDays(-30))" asp-route-end="@iso(DateTime.UtcNow)">Last 30 Days</a>
    </p>

    <hr />

    <form method="get" asp-action="Report" class="form-row align-items-end mb-4">
        <div class="form-group col-md-3">
            <label for="start">Start date (UTC)</label>
            <input id="start" name="start" type="date" class="form-control"
                   value="@(Model.StartDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat))" />
        </div>
        <div class="form-group col-md-3">
            <label for="end">End date (UTC)</label>
            <input id="end" name="end" type="date" class="form-control"
                   value="@(Model.EndDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat))" />
        </div>
        <div class="form-group col-md-2">
            <button type="submit" class="btn btn-primary">Run</button>
        </div>
    </form>

    <p>
        Time Range:
        @Model.StartDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat)
        – @Model.EndDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat)
        &nbsp;·&nbsp; <strong>@Model.TotalEvents</strong> filter actions
        &nbsp;·&nbsp; Video: <strong>@Model.VideoCount</strong>, Tor: <strong>@Model.TorCount</strong>, I2P: <strong>@Model.I2pCount</strong>
    </p>

    @if (Model.LeadingCategory != null || Model.LeadingSubcategory != null)
    {
        <div style="border:1px solid var(--orange,#ff6600);border-radius:8px;padding:.6rem .9rem;margin:0 0 1rem;">
            @if (Model.LeadingCategory != null)
            {
                <div><strong>Leading category:</strong> @Model.LeadingCategory</div>
            }
            @if (Model.LeadingSubcategory != null)
            {
                <div><strong>Leading subcategory:</strong> @Model.LeadingSubcategory
                    <span style="opacity:.8;">&nbsp;(shown as <em>Category › Subcategory</em>)</span>
                </div>
            }
        </div>
    }

    @{
        void RenderTable(string title, string colName, IReadOnlyList<DirectoryManager.Web.Models.FilterReportItem> items)
        {
            <h3>@title</h3>
            if (items.Count == 0)
            {
                <p><em>No data in this range.</em></p>
            }
            else
            {
                <div class="table-wrapper">
                    <table class="table table-striped table-sm">
                        <thead>
                            <tr><th>@colName</th><th class="text-right">Count</th><th class="text-right">% of actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in items)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td class="text-right">@item.Count</td>
                                    <td class="text-right">@item.Percentage.ToString("0.00")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }

    @{ RenderTable("Categories", "Category", Model.Categories); }
    @{ RenderTable("Subcategories", "Subcategory (Category › Subcategory)", Model.Subcategories); }
    @{ RenderTable("Statuses", "Status", Model.Statuses); }
    @{ RenderTable("Tags", "Tag", Model.Tags); }
    @{ RenderTable("Search terms", "Term", Model.Terms); }
    @{ RenderTable("Countries", "Country", Model.Countries); }
}
