@using DirectoryManager.Web.Services.Interfaces
@using System.Globalization
@using DirectoryManager.Data.Models.Reviews
@using DirectoryManager.Web.Helpers
@using DirectoryManager.Utilities.Helpers
@using DirectoryManager.DisplayFormatting.Helpers
@inject DirectoryManager.Web.Services.Interfaces.ICacheService cacheHelper
@model DirectoryManager.Web.Models.Reviews.EntryReviewsBlockViewModel
@inject IUrlResolutionService Urls

@{
    // ✅ With paging, Model.Reviews is only the current page
    int total = Model?.ReviewCount ?? 0;

    int c5 = Model?.Rating5Count ?? 0;
    int c4 = Model?.Rating4Count ?? 0;
    int c3 = Model?.Rating3Count ?? 0;
    int c2 = Model?.Rating2Count ?? 0;
    int c1 = Model?.Rating1Count ?? 0;

    double P(int count) => total <= 0 ? 0 : (count * 100.0 / total);

    bool showPager = (Model?.TotalPages ?? 1) > 1;
    int currentPage = Model?.CurrentPage ?? 1;
    int totalPages = Model?.TotalPages ?? 1;
    string entryKey = Model?.DirectoryEntryKey ?? string.Empty;

    bool reviewsDisabled = Model?.ReviewsDisabled ?? false;

    // ✅ Hover shows exact time to the minute
    string HoverMinute(DateTime dt) => dt.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat4, CultureInfo.InvariantCulture);

    // ✅ datetime attribute uses minute precision (valid-ish ISO local)
    string DateTimeMinuteAttr(DateTime dt) => dt.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat3, CultureInfo.InvariantCulture);
}

@{
    var authorCounts = Model?.AuthorPostCountsByFingerprint
        ?? new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

    int PostsFor(string? fp)
    {
        var key = (fp ?? string.Empty).Trim();
        return authorCounts.TryGetValue(key, out var cnt) ? cnt : 0;
    }
}

<div class="reviews-block mt-4">
    <h3 id="reviews" class="mb-3">Reviews</h3>

    @if (reviewsDisabled)
    {
        <div class="alert alert-secondary reviews-disabled-notice" role="status">
            <strong>Reviews are closed for this listing.</strong>
            Existing reviews remain visible, but new reviews and replies are not being accepted.
        </div>
    }

    @if (Model.ShowRequestVerification)
    {
        <div class="verification-request-notice mb-4">
            <span class="vr-text">This listing hasn't been verified by @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)) yet.</span>
            <form action="@Urls.ResolveToApp("/verification-requests/begin")"
                  method="post"
                  class="d-inline"
                  rel="nofollow">
                <input type="hidden" name="directoryEntryId" value="@Model.DirectoryEntryId" />
                <input type="text" name="website" value="" style="display:none" tabindex="-1" autocomplete="off" />
                <button class="btn review-btn btn-sm" type="submit">Request verification</button>
            </form>
        </div>
    }

    @if (Model.OfficialReviews != null && Model.OfficialReviews.Any())
    {
        <div class="official-reviews mb-4">
            @foreach (var o in Model.OfficialReviews)
            {
                <div id="review-@o.DirectoryEntryReviewId"
                     class="official-review"
                     itemscope
                     itemtype="https://schema.org/Review">

                    <div class="official-badge">
                        <span class="official-badge-dot" aria-hidden="true"></span>
                        Official review
                    </div>

                    <span itemprop="author" itemscope itemtype="https://schema.org/Organization">
                        <meta itemprop="name" content="@(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName))" />
                    </span>

                    @if (o.Rating.HasValue)
                    {
                        <div class="d-flex align-items-center mt-2">
                            @EntryReviewHtmlHelper.RenderSingleReviewStars(o.Rating)
                            <small class="text-muted ms-2">@o.Rating/5</small>
                            <span itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
                                <meta itemprop="ratingValue" content="@((o.Rating ?? 0))" />
                                <meta itemprop="bestRating" content="5" />
                                <meta itemprop="worstRating" content="1" />
                            </span>
                        </div>
                    }

                    @EntryReviewHtmlHelper.RenderReviewTags(o)

                    <div class="mt-2" itemprop="reviewBody">
                        @Html.Raw(StringHelpers.RenderBodyWithLinksHtml(o.Body, cssClass: "multi-line-text", ugcContent: false))
                    </div>

                    @if (!string.IsNullOrWhiteSpace(o.OrderUrl)
                         || !string.IsNullOrWhiteSpace(o.SendingTxUrl)
                         || !string.IsNullOrWhiteSpace(o.ReceivingTxUrl)
                         || !string.IsNullOrWhiteSpace(o.ImageUrl)
                         || !string.IsNullOrWhiteSpace(o.AmlScreenshotUrl))
                    {
                        <ul class="official-links mt-3 list-unstyled">
                            @if (!string.IsNullOrWhiteSpace(o.OrderUrl))
                            {
                                <li>
                                    <a href="@o.OrderUrl" target="_blank" rel="nofollow noopener noreferrer">Order URL ↗</a>
                                </li>
                            }
                            @if (!string.IsNullOrWhiteSpace(o.SendingTxUrl))
                            {
                                <li>
                                    <a href="@o.SendingTxUrl" target="_blank" rel="nofollow noopener noreferrer">Sending transaction ↗</a>
                                </li>
                            }
                            @if (!string.IsNullOrWhiteSpace(o.ReceivingTxUrl))
                            {
                                <li>
                                    <a href="@o.ReceivingTxUrl" target="_blank" rel="nofollow noopener noreferrer">Receiving transaction ↗</a>
                                </li>
                            }
                            @if (!string.IsNullOrWhiteSpace(o.ImageUrl))
                            {
                                <li>
                                    <a href="@o.ImageUrl" target="_blank" rel="nofollow noopener noreferrer">Screenshot ↗</a>
                                </li>
                            }
                            @if (!string.IsNullOrWhiteSpace(o.AmlScreenshotUrl))
                            {
                                <li>
                                    <a href="@o.AmlScreenshotUrl" target="_blank" rel="nofollow noopener noreferrer">AML check ↗</a>
                                </li>
                            }
                        </ul>
                    }

                    @if (!string.IsNullOrWhiteSpace(o.OrderProofContext))
                    {
                        <details class="official-verification mt-3">
                            <summary class="official-verification-summary">Verification details</summary>
                            <div class="official-verification-body mt-2" itemprop="description">
                                @Html.Raw(StringHelpers.RenderBodyWithLinksHtml(o.OrderProofContext, cssClass: "multi-line-text", ugcContent: false))
                            </div>
                        </details>
                    }

                    <div class="official-meta mt-2">
                        <small class="text-muted">
                            Official review by @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)).
                            @if (o.TestedAt.HasValue)
                            {
                                <span class="ms-1">
                                    Tested
                                    <time datetime="@o.TestedAt.Value.ToString("yyyy-MM-dd")">
                                        @o.TestedAt.Value.ToString("yyyy-MM-dd")
                                    </time> 
                                </span>
                            }
                        </small>
                    </div>

                    @await Html.PartialAsync("_ReviewRepliesBlock", new DirectoryManager.Web.Models.Reviews.ReviewRepliesBlockViewModel
                    {
                        DirectoryEntryReviewId = o.DirectoryEntryReviewId,
                        ReviewsDisabled = reviewsDisabled,
                        Replies = EntryReviewHtmlHelper.GetReplies(Model.RepliesByReviewId, o.DirectoryEntryReviewId),
                        AuthorPostCountsByFingerprint = authorCounts
                    })
                </div>
            }
        </div>
    }

    @if (Model.ReviewCount > 0)
    {
        <div class="rating-summary" aria-label="Review summary">
            <div class="rs-left">
                <div class="rs-avg">@Model.AverageRating.Value.ToString("0.0")</div>

                <div class="rs-stars">
                    @EntryReviewHtmlHelper.RenderAggregateStars(Model.AverageRating, Model.ReviewCount, starsOnly: true)
                </div>

                <div class="rs-count">@Model.ReviewCount rating@(Model.ReviewCount == 1 ? "" : "s")</div>
            </div>

            <div class="rs-right" aria-label="Rating distribution">
                <div class="rating-row">
                    <div class="rating-num">5</div>
                    <div class="rating-track">
                        <div class="rating-fill" style="width:@P(c5).ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="rating-pct">@Math.Round(P(c5))%</div>
                </div>

                <div class="rating-row">
                    <div class="rating-num">4</div>
                    <div class="rating-track">
                        <div class="rating-fill" style="width:@P(c4).ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="rating-pct">@Math.Round(P(c4))%</div>
                </div>

                <div class="rating-row">
                    <div class="rating-num">3</div>
                    <div class="rating-track">
                        <div class="rating-fill" style="width:@P(c3).ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="rating-pct">@Math.Round(P(c3))%</div>
                </div>

                <div class="rating-row">
                    <div class="rating-num">2</div>
                    <div class="rating-track">
                        <div class="rating-fill" style="width:@P(c2).ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="rating-pct">@Math.Round(P(c2))%</div>
                </div>

                <div class="rating-row">
                    <div class="rating-num">1</div>
                    <div class="rating-track">
                        <div class="rating-fill" style="width:@P(c1).ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="rating-pct">@Math.Round(P(c1))%</div>
                </div>
            </div>
        </div>
    }

    @if (!reviewsDisabled)
    {
        <div class="leave-review-cta mb-4">
            <form action="@Urls.ResolveToApp("/directory-entry-reviews/begin")"
                  method="post"
                  class="d-inline"
                  rel="nofollow">
                <input type="hidden" name="directoryEntryId" value="@Model.DirectoryEntryId" />
                <button class="btn review-btn" type="submit">Leave a review</button>
            </form>
        </div>
    }

    @if (Model.ReviewCount > 0 && Model.Reviews != null && Model.Reviews.Any())
    {
        <ul class="list-unstyled">
            @foreach (var r in Model.Reviews)
            {
                var replies = EntryReviewHtmlHelper.GetReplies(Model.RepliesByReviewId, r.DirectoryEntryReviewId);

                <li id="review-@r.DirectoryEntryReviewId"
                    class="mb-4 pb-3 border-bottom"
                    itemscope
                    itemtype="https://schema.org/Review">

                    @if (r.IsOwner)
                    {
                        <div class="owner-badge mb-1">
                            <span class="owner-badge-mark" aria-hidden="true">✓</span>
                            @(string.IsNullOrWhiteSpace(r.DisplayName) ? "Listing owner" : r.DisplayName) (listing owner)
                        </div>
                    }

                    <div class="d-flex align-items-center">
                        @EntryReviewHtmlHelper.RenderSingleReviewStars(r.Rating)
                        <small class="text-muted ms-2">@r.Rating/5</small>

                        <span itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
                            <meta itemprop="ratingValue" content="@((r.Rating ?? 0))" />
                            <meta itemprop="bestRating" content="5" />
                            <meta itemprop="worstRating" content="1" />
                        </span>
                    </div>

                    <!-- ✅ Tags -->
                    @EntryReviewHtmlHelper.RenderReviewTags(r)

                    <div class="mt-2" itemprop="reviewBody">
                        @Html.Raw(StringHelpers.RenderBodyWithLinksHtml(r.Body, cssClass: "multi-line-text", ugcContent: true))
                    </div>

                    <div class="mt-2">
                        <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                            <meta itemprop="name" content="@(string.IsNullOrWhiteSpace(r.DisplayName) ? r.AuthorFingerprint : r.DisplayName)" />
                            <small class="text-muted multi-line-text">
                                Author: @(string.IsNullOrWhiteSpace(r.DisplayName) ? r.AuthorFingerprint : r.DisplayName)
                                <span class="ms-1">(posts: @PostsFor(r.AuthorFingerprint))</span>
                            </small>
                        </span>
                        <small class="text-muted ms-2">•</small>
                        <time class="text-muted ms-2"
                              itemprop="datePublished"
                              datetime="@DateTimeMinuteAttr(r.CreateDate)"
                              title="@HoverMinute(r.CreateDate)">
                            @r.CreateDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)
                        </time>
                    </div>

                    @await Html.PartialAsync("_ReviewRepliesBlock", new DirectoryManager.Web.Models.Reviews.ReviewRepliesBlockViewModel
                    {
                        DirectoryEntryReviewId = r.DirectoryEntryReviewId,
                        ReviewsDisabled = reviewsDisabled,
                        Replies = replies,
                        AuthorPostCountsByFingerprint = authorCounts
                    })
                </li>
            }
        </ul>

        @* ✅ Review pagination (ONLY show if more than 1 page) *@
        @if (showPager && !string.IsNullOrWhiteSpace(entryKey))
        {
            <nav aria-label="Review pages">
                <ul class="pagination">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        // ✅ single source of truth for listing path: /site/{key}
                        string basePath = UrlBuilder.ListingPath(entryKey);

                        string rawPath = (p == 1)
                            ? basePath
                            : $"{basePath}/page/{p}";

                        string href = Urls.ResolveToRoot(rawPath);

                        if (p == currentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link" aria-current="page">@p</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link no-app-link" href="@href">@p</a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <p class="text-muted">No reviews yet.</p>
    }
</div>