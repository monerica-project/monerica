@using DirectoryManager.Data.Enums
@using DirectoryManager.Utilities.Helpers
@using DirectoryManager.Web.Constants
@using Microsoft.AspNetCore.WebUtilities
@using DirectoryManager.DisplayFormatting.Helpers
@using DirectoryManager.Web.Models
@using DirectoryManager.Web.Services.Interfaces
@inject IUrlResolutionService urlService
@inject DirectoryManager.Data.Repositories.Interfaces.IDirectoryEntryReviewRepository reviewRepo
@model DirectoryFilterViewModel

@{
    Layout = "_WideLayout";
    ViewData[StringConstants.TitleHeader] = "Directory Filter";
    ViewData[StringConstants.MetaContent] = StringConstants.MetaTagNoIndex;

    var selectedStatuses = new HashSet<DirectoryStatus>(Model.Query.Statuses ?? new List<DirectoryStatus>());
    var orderedStatuses = new[]
    {
        DirectoryStatus.Verified,
        DirectoryStatus.Admitted,
        DirectoryStatus.Questionable,
        DirectoryStatus.Scam
    };

    var selectedTagIds = new HashSet<int>(Model.Query.TagIds ?? new List<int>());
    var hasCategoryForTags = Model.Query.CategoryId.HasValue && Model.Query.CategoryId.Value > 0;

    var sortLabels = new (DirectoryFilterSort Value, string Label)[]
    {
        (DirectoryFilterSort.TopRated,             "Highest trust (default)"),
        (DirectoryFilterSort.HighestRating,        "Highest rating"),
        (DirectoryFilterSort.LowestRating,         "Lowest rating"),
        (DirectoryFilterSort.Newest,               "Newest added"),
        (DirectoryFilterSort.Oldest,               "Oldest added"),
        (DirectoryFilterSort.FoundedDateNewest,    "Founded: Newest"),
        (DirectoryFilterSort.FoundedDateOldest,    "Founded: Oldest"),
        (DirectoryFilterSort.NameAsc,              "Name A-Z"),
        (DirectoryFilterSort.NameDesc,             "Name Z-A"),
        (DirectoryFilterSort.RecentlyUpdated,      "Recently updated"),
        (DirectoryFilterSort.LeastRecentlyUpdated, "Least recently updated"),
    };

    var domain = (urlService.BaseUrl ?? string.Empty).TrimEnd('/');

    var clearUrl = (Url.Action("Index", "DirectoryFilter") ?? "/filter")
        + "?Page=1&PageSize=" + Model.Query.PageSize;

    // -----------------------------------------------------------------
    // Sponsor rating + profile-link resolution (for the sponsor blocks).
    // -----------------------------------------------------------------
    var sponsorIds = new List<int>();
    var subVm = Model?.SubcategorySponsorModel?.DirectoryEntry;
    var catVm = Model?.CategorySponsorModel?.DirectoryEntry;

    if (subVm != null && subVm.DirectoryEntryId > 0)
    {
        sponsorIds.Add(subVm.DirectoryEntryId);
    }

    if (catVm != null && catVm.DirectoryEntryId > 0)
    {
        sponsorIds.Add(catVm.DirectoryEntryId);
    }

    var sponsorRatings = new Dictionary<int, DirectoryManager.Data.Models.TransferModels.RatingSummaryDto>();
    if (sponsorIds.Count > 0)
    {
        sponsorRatings = await reviewRepo.GetRatingSummariesAsync(sponsorIds);
    }

    if (subVm != null)
    {
        if (sponsorRatings.TryGetValue(subVm.DirectoryEntryId, out var subSum))
        {
            subVm.AverageRating = subSum.ReviewCount > 0 ? subSum.AvgRating : null;
            subVm.ReviewCount = subSum.ReviewCount > 0 ? subSum.ReviewCount : null;
        }

        subVm.LinkType = DirectoryManager.DisplayFormatting.Enums.LinkType.ListingPage;
        if (string.IsNullOrWhiteSpace(subVm.ItemPath))
        {
            subVm.ItemPath = UrlBuilder.ListingPath(subVm.DirectoryEntryKey);
        }
    }

    if (catVm != null)
    {
        if (sponsorRatings.TryGetValue(catVm.DirectoryEntryId, out var catSum))
        {
            catVm.AverageRating = catSum.ReviewCount > 0 ? catSum.AvgRating : null;
            catVm.ReviewCount = catSum.ReviewCount > 0 ? catSum.ReviewCount : null;
        }

        catVm.LinkType = DirectoryManager.DisplayFormatting.Enums.LinkType.ListingPage;
        if (string.IsNullOrWhiteSpace(catVm.ItemPath))
        {
            catVm.ItemPath = UrlBuilder.ListingPath(catVm.DirectoryEntryKey);
        }
    }

    // -----------------------------------------------------------------
    // Pagination math + pager HTML (built as a string to keep the markup
    // free of nested code transitions). Emitted later via @Html.Raw.
    // -----------------------------------------------------------------
    var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.Query.PageSize);
    if (totalPages < 1)
    {
        totalPages = 1;
    }

    var currentPage = Model.Query.Page < 1 ? 1 : Model.Query.Page;
    if (currentPage > totalPages)
    {
        currentPage = totalPages;
    }

    var pagerHtml = string.Empty;
    if (totalPages > 1)
    {
        var keptQuery = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        foreach (var kv in Context.Request.Query)
        {
            if (string.Equals(kv.Key, "Page", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (string.Equals(kv.Key, "Statuses", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (string.Equals(kv.Key, "TagIds", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            keptQuery[kv.Key] = kv.Value.ToString();
        }

        string BuildUrlForPage(int page)
        {
            var url = Url.Action("Index", "DirectoryFilter") ?? "/filter";
            var qs = new Dictionary<string, string?>(keptQuery)
            {
                ["Page"] = page.ToString(),
                ["PageSize"] = Model.Query.PageSize.ToString()
            };

            var built = QueryHelpers.AddQueryString(url, qs);

            if (Model.Query.Statuses != null && Model.Query.Statuses.Count > 0)
            {
                foreach (var st in Model.Query.Statuses)
                {
                    built = QueryHelpers.AddQueryString(built, "Statuses", st.ToString());
                }
            }

            if (Model.Query.TagIds != null && Model.Query.TagIds.Count > 0)
            {
                foreach (var tid in Model.Query.TagIds)
                {
                    built = QueryHelpers.AddQueryString(built, "TagIds", tid.ToString());
                }
            }

            return built;
        }

        var cells = new List<(string Text, string Url, bool Active, bool Disabled)>();
        var hasPrev = currentPage > 1;
        var hasNext = currentPage < totalPages;
        const int windowSize = 2;
        var windowStart = Math.Max(1, currentPage - windowSize);
        var windowEnd = Math.Min(totalPages, currentPage + windowSize);

        cells.Add(("\u00AB", hasPrev ? BuildUrlForPage(currentPage - 1) : "#", false, !hasPrev));

        if (windowStart > 1)
        {
            cells.Add(("1", BuildUrlForPage(1), false, false));
            if (windowStart > 2)
            {
                cells.Add(("\u2026", "#", false, true));
            }
        }

        for (var p = windowStart; p <= windowEnd; p++)
        {
            cells.Add((p.ToString(), BuildUrlForPage(p), p == currentPage, false));
        }

        if (windowEnd < totalPages)
        {
            if (windowEnd < totalPages - 1)
            {
                cells.Add(("\u2026", "#", false, true));
            }

            cells.Add((totalPages.ToString(), BuildUrlForPage(totalPages), false, false));
        }

        cells.Add(("\u00BB", hasNext ? BuildUrlForPage(currentPage + 1) : "#", false, !hasNext));

        var sb = new System.Text.StringBuilder();
        sb.Append("<nav aria-label=\"Directory pagination\"><ul class=\"pagination\">");
        foreach (var cell in cells)
        {
            var liClass = "page-item";
            if (cell.Active)
            {
                liClass += " active";
            }

            if (cell.Disabled)
            {
                liClass += " disabled";
            }

            sb.Append("<li class=\"").Append(liClass).Append("\">");
            if (cell.Disabled)
            {
                sb.Append("<span class=\"page-link\">")
                  .Append(System.Net.WebUtility.HtmlEncode(cell.Text))
                  .Append("</span>");
            }
            else
            {
                sb.Append("<a class=\"page-link\" href=\"")
                  .Append(System.Net.WebUtility.HtmlEncode(cell.Url))
                  .Append("\">")
                  .Append(System.Net.WebUtility.HtmlEncode(cell.Text))
                  .Append("</a>");
            }

            sb.Append("</li>");
        }

        sb.Append("</ul></nav>");
        pagerHtml = sb.ToString();
    }
}

@section PageContent {

<div class="filter-shell">

    <div class="page-header-bar">
        <h1 class="page-title">Directory Filter</h1>
        @await Html.PartialAsync("_SiteLogo")
    </div>

    @await Html.PartialAsync("_BackToHome")

    <div class="filter-layout">

        @* No-JS mobile toggle: a hidden checkbox + the label below drive the
           sidebar's visibility purely through CSS (:checked sibling selector). *@
        <input type="checkbox" id="filter-open" class="filter-open-toggle" hidden />

        @* ============================ SIDEBAR ============================ *@
        <aside class="filter-sidebar" id="filter-sidebar">
            <form method="get" class="filter-form ui-form">

                <div class="filter-sidebar-head">
                    <span class="filter-sidebar-title">Filters</span>
                    <a class="no-app-link ui-clear" href="@clearUrl">Clear</a>
                </div>

                <!-- Search -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Search</legend>
                    <input type="search" name="SearchTerm" value="@Model.Query.SearchTerm"
                           class="dir-search-input" size="1"
                           placeholder="Name, description, tag…"
                           autocomplete="off" />
                </fieldset>

                <!-- Sort -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Sort</legend>
                    <div class="ui-select-wrap">
                        <select name="Sort" class="form-control select-fit ui-select">
                            @foreach (var opt in sortLabels)
                            {
                                <option value="@opt.Value" selected="@(Model.Query.Sort == opt.Value ? "selected" : null)">@opt.Label</option>
                            }
                        </select>
                    </div>
                </fieldset>

                <!-- Status -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Status</legend>
                    <div class="ui-checks ui-checks-stack">
                        @foreach (var st in orderedStatuses)
                        {
                            <label class="ui-check">
                                <input type="checkbox" name="Statuses" value="@st" checked="@(selectedStatuses.Contains(st) ? "checked" : null)" />
                                <span>@st</span>
                            </label>
                        }
                    </div>
                </fieldset>

                <!-- Networks / Links -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Networks</legend>
                    <div class="ui-checks ui-checks-stack">
                        <label class="ui-check">
                            <input type="checkbox" name="HasTor" value="true" checked="@(Model.Query.HasTor ? "checked" : null)" />
                            <span>Has Tor (.onion)</span>
                        </label>
                        <label class="ui-check">
                            <input type="checkbox" name="HasI2p" value="true" checked="@(Model.Query.HasI2p ? "checked" : null)" />
                            <span>Has I2P (.i2p)</span>
                        </label>
                        <label class="ui-check">
                            <input type="checkbox" name="HasVideo" value="true" checked="@(Model.Query.HasVideo ? "checked" : null)" />
                            <span>Has Video</span>
                        </label>
                    </div>
                </fieldset>

                <!-- Country -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Country</legend>
                    <div class="ui-select-wrap">
                        <select name="Country" class="form-control select-fit ui-select">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Query.Country) ? "selected" : null)">All countries</option>
                            @foreach (var c in Model.CountryOptions)
                            {
                                var isSelectedCountry = string.Equals(Model.Query.Country, c.Code, StringComparison.OrdinalIgnoreCase);
                                <option value="@c.Code" selected="@(isSelectedCountry ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                </fieldset>

                <!-- Categorization -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">Category</legend>

                    <div class="ui-select-wrap">
                        <select name="CategoryId" class="form-control select-fit ui-select">
                            <option value="" selected="@(!(Model.Query.CategoryId > 0) ? "selected" : null)">All categories</option>
                            @foreach (var cat in Model.CategoryOptions)
                            {
                                <option value="@cat.Id" selected="@(Model.Query.CategoryId == cat.Id ? "selected" : null)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    @if (hasCategoryForTags)
                    {
                        <div class="ui-select-wrap" style="margin-top:8px;">
                            <select name="SubCategoryId" class="form-control select-fit ui-select">
                                <option value="" selected="@(!(Model.Query.SubCategoryId > 0) ? "selected" : null)">All subcategories</option>
                                @foreach (var sc in Model.SubCategoryOptions)
                                {
                                    <option value="@sc.Id" selected="@(Model.Query.SubCategoryId == sc.Id ? "selected" : null)">@sc.Name</option>
                                }
                            </select>
                        </div>
                    }
                </fieldset>

                <!-- Tags -->
                <fieldset class="ui-fieldset">
                    <legend class="ui-legend">@(hasCategoryForTags ? "Tags (in category)" : "Tags")</legend>
                    @if (Model.CategoryTagOptions == null || Model.CategoryTagOptions.Count == 0)
                    {
                        <div class="ui-empty"><i>@(hasCategoryForTags ? "No tags for this category." : "No tags found.")</i></div>
                    }
                    else
                    {
                        // No-JS "show all": a hidden checkbox precedes the list; CSS hides
                        // tags past the 6th until it is checked. Toggle only rendered when
                        // there are more than 6 tags.
                        if (Model.CategoryTagOptions.Count > 6)
                        {
                            <input type="checkbox" id="show-all-tags" class="dir-tags-toggle" hidden />
                        }

                        <div class="ui-checks ui-checks-stack dir-tags">
                            @foreach (var t in Model.CategoryTagOptions)
                            {
                                <label class="ui-check">
                                    <input type="checkbox" name="TagIds" value="@t.Id" checked="@(selectedTagIds.Contains(t.Id) ? "checked" : null)" />
                                    <span>@t.Name</span>
                                </label>
                            }
                        </div>

                        if (Model.CategoryTagOptions.Count > 6)
                        {
                            <label class="dir-tags-more" for="show-all-tags"></label>
                        }
                    }
                </fieldset>

                @* Page size has no UI; it defaults to a sensible value in the controller.
                   Kept as a hidden field so a URL-supplied PageSize still round-trips. *@
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="Page" value="1" />

                <div class="filter-actions">
                    <button type="submit" class="btn btn-primary btn-cta">Apply Filters</button>
                </div>
            </form>
        </aside>

        @* ============================ RESULTS ============================ *@
        <section class="filter-results">

            @if (Model?.SubcategorySponsorModel != null)
            {
                @await Html.PartialAsync("_SponsoredListingSubCategoryPartial", Model.SubcategorySponsorModel)
            }
            else if (Model?.CategorySponsorModel != null)
            {
                @await Html.PartialAsync("_SponsoredListingCategoryPartial", Model.CategorySponsorModel)
            }

            <div class="results-bar">
                <span class="results-count">@Model.TotalCount result@(Model.TotalCount == 1 ? "" : "s")</span>
                @if (!string.IsNullOrWhiteSpace(Model.Query.SearchTerm))
                {
                    <a class="results-search-chip no-app-link" href="@clearUrl" title="Clear search">&ldquo;@Model.Query.SearchTerm&rdquo; &times;</a>
                }
                <span class="results-page">Page @currentPage of @totalPages</span>
                <label class="filter-toggle" for="filter-open">Filters</label>
            </div>

            @if (!Model.Entries.Any())
            {
                <div class="results-empty">
                    <p>No results match your filters.</p>
                    <a class="no-app-link" href="@(Url.Action("Index", "DirectoryFilter") ?? "/filter")">Reset filters</a>
                </div>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var e in Model.Entries)
                    {
                        var isScam = e.DirectoryStatus == DirectoryStatus.Scam;
                        var isQuestionable = e.DirectoryStatus == DirectoryStatus.Questionable;
                        var isVerified = e.DirectoryStatus == DirectoryStatus.Verified;
                        var isAdmitted = e.DirectoryStatus == DirectoryStatus.Admitted;

                        var cardClasses = "dir-card";
                        if (e.IsSponsored)
                        {
                            cardClasses += " is-featured";
                        }

                        if (isScam)
                        {
                            cardClasses += " is-scam";
                        }
                        else if (isQuestionable)
                        {
                            cardClasses += " is-questionable";
                        }
                        else if (isVerified)
                        {
                            cardClasses += " is-verified";
                        }
                        else if (isAdmitted)
                        {
                            cardClasses += " is-admitted";
                        }

                        // Status glyph: verified ✅ green, admitted 🔵 blue,
                        // questionable ❓ red, scam ❌ red.
                        var statusIcon = isVerified ? "&#9989;"
                            : isAdmitted ? "&#128309;"
                            : isQuestionable ? "&#10067;"
                            : isScam ? "&#10060;"
                            : string.Empty;

                        var itemPath = (e.ItemPath ?? string.Empty).Trim();
                        if (!itemPath.StartsWith("/"))
                        {
                            itemPath = "/" + itemPath;
                        }

                        var profUrl = string.IsNullOrEmpty(domain) ? itemPath : domain + itemPath;
                        var reviewsUrl = profUrl + "#reviews";

                        // Link resolution (mirrors search-result rel rules).
                        var websiteAff = !string.IsNullOrWhiteSpace(e.LinkA) && !e.IsSponsored;
                        var websiteUrl = websiteAff ? e.LinkA!.Trim() : (e.Link ?? string.Empty).Trim();
                        var websiteRel = (e.IsSponsored || websiteAff) ? "sponsored noopener" : "noopener";

                        var torAff = !string.IsNullOrWhiteSpace(e.Link2A) && !e.IsSponsored;
                        var torUrl = torAff ? e.Link2A!.Trim() : (e.Link2 ?? string.Empty).Trim();
                        var torLabel = string.IsNullOrWhiteSpace(e.Link2Name) ? "Tor" : e.Link2Name;
                        var torRel = (e.IsSponsored || torAff) ? "sponsored noopener" : "noopener";

                        var i2pAff = !string.IsNullOrWhiteSpace(e.Link3A) && !e.IsSponsored;
                        var i2pUrl = i2pAff ? e.Link3A!.Trim() : (e.Link3 ?? string.Empty).Trim();
                        var i2pLabel = string.IsNullOrWhiteSpace(e.Link3Name) ? "I2P" : e.Link3Name;
                        var i2pRel = (e.IsSponsored || i2pAff) ? "sponsored noopener" : "noopener";

                        var hasRating = e.AverageRating.HasValue && (e.ReviewCount ?? 0) > 0;
                        var ratingVal = e.AverageRating ?? 0;
                        var ratingPct = Math.Clamp(ratingVal / 5.0 * 100, 0, 100);
                        var ratingPctStr = ratingPct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                        var ratingValStr = ratingVal.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);

                        // Category breadcrumb (null-safe).
                        var subCat = e.SubCategory;
                        var cat = subCat?.Category;
                        var catKey = cat?.CategoryKey;
                        var catName = cat?.Name;
                        var subKey = subCat?.SubCategoryKey;
                        var subName = subCat?.Name;
                        var hasBreadcrumb = subCat != null && !string.IsNullOrWhiteSpace(catKey);
                        var catUrl = domain + "/" + catKey;
                        var subUrl = domain + "/" + catKey + "/" + subKey;

                        // Meta chips. Location/city is intentionally omitted —
                        // it's rarely meaningful for online services and often
                        // overflows the chip row.
                        var metaBits = new List<string>();
                        if (e.FoundedDate.HasValue)
                        {
                            metaBits.Add("Est. " + e.FoundedDate.Value.Year.ToString());
                        }

                        if (!string.IsNullOrWhiteSpace(e.Processor))
                        {
                            metaBits.Add(e.Processor);
                        }

                        <article class="@cardClasses">

                            <header class="dir-card-head">
                                <div class="dir-title-wrap">
                                    <span class="dir-name-row">
                                        <span class="dir-status-icon">@Html.Raw(statusIcon)</span>
                                        @if (isScam)
                                        {
                                            <a class="dir-name no-app-link is-scam-name" href="@profUrl"><del>@e.Name</del></a>
                                        }
                                        else
                                        {
                                            <a class="dir-name no-app-link" href="@profUrl">@e.Name</a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(e.CountryCode))
                                        {
                                            @Html.Raw(DisplayMarkUpHelper.BuildCountryFlagImgTag(e.CountryCode))
                                        }
                                    </span>
                                    @if (e.IsSponsored)
                                    {
                                        <span class="dir-badge-featured">Sponsored</span>
                                    }
                                </div>

                                <div class="dir-score @(hasRating ? "" : "is-none")">
                                    @if (hasRating)
                                    {
                                        <span class="dir-score-num">@ratingValStr</span>
                                    }
                                    else
                                    {
                                        <span class="dir-score-num">&ndash;</span>
                                    }
                                </div>
                            </header>

                            @if (hasRating)
                            {
                                <a class="dir-rating-link" href="@reviewsUrl" aria-label="@ratingValStr out of 5 from @e.ReviewCount reviews">
                                    <span class="rating-wrapper">
                                        <span class="stars"><span class="stars-fill" style="width:@(ratingPctStr)%"></span></span>
                                        <span class="rating-count">(@e.ReviewCount)</span>
                                    </span>
                                </a>
                            }

                            @if (hasBreadcrumb)
                            {
                                <div class="dir-breadcrumb">
                                    <a class="dir-chip no-app-link" href="@catUrl">@catName</a>
                                    <span class="dir-chip-sep">&rsaquo;</span>
                                    <a class="dir-chip no-app-link" href="@subUrl">@subName</a>
                                </div>
                            }

                            @if (metaBits.Count > 0)
                            {
                                <div class="dir-meta">
                                    @foreach (var bit in metaBits)
                                    {
                                        <span class="dir-meta-chip">@bit</span>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(e.Description))
                            {
                                <p class="dir-desc">@e.Description</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(e.Note))
                            {
                                var noteClass = (isScam || isQuestionable) ? "dir-note is-warning" : "dir-note";
                                <p class="@noteClass">
                                    <span class="dir-note-label">Note:</span> @Html.Raw(e.Note)
                                </p>
                            }

                            <footer class="dir-card-foot">
                                @{
                                    var hasAnyLink = !string.IsNullOrWhiteSpace(websiteUrl)
                                        || !string.IsNullOrWhiteSpace(torUrl)
                                        || !string.IsNullOrWhiteSpace(i2pUrl);
                                }
                                @if (!string.IsNullOrWhiteSpace(websiteUrl))
                                {
                                    <a class="dir-link-btn" target="_blank" href="@websiteUrl" rel="@websiteRel">Website</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(torUrl))
                                {
                                    <a class="dir-link-btn dir-link-tor" target="_blank" href="@torUrl" rel="@torRel">@torLabel</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(i2pUrl))
                                {
                                    <a class="dir-link-btn dir-link-i2p" target="_blank" href="@i2pUrl" rel="@i2pRel">@i2pLabel</a>
                                }
                                @if (!hasAnyLink)
                                {
                                    <a class="dir-link-btn dir-link-profile no-app-link" href="@profUrl">Details</a>
                                }
                            </footer>
                        </article>
                    }
                </div>

                <div class="pager-wrap">@Html.Raw(pagerHtml)</div>
            }

            <hr />
            @await Html.PartialAsync("_SponsoredListingPartial")
        </section>
    </div>
</div>
}