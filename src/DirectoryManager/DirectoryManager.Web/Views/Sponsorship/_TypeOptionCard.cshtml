@model DirectoryManager.Web.Models.Sponsorship.TypeOptionCardVm
@using System.Globalization
@using DirectoryManager.Web.Helpers
@using DirectoryManager.Data.Enums
@using Microsoft.Extensions.Caching.Memory
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpContextAccessor
@inject DirectoryManager.Common.Interfaces.IRateConversionService rateConversionService
@inject IMemoryCache memoryCache

@{
    var conversionResult = await CurrencyConversionHelper.GetConversionContextAsync(
        httpContextAccessor,
        memoryCache,
        rateConversionService
    );

    bool showConverted = conversionResult.showConverted;
    decimal conversionRate = conversionResult.conversionRate;
}

@functions {
    private static string FormatUtcFull(DateTime utc) =>
        utc.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat, CultureInfo.InvariantCulture) + " UTC";

    private static string FormatCountdown(DateTime utc, DateTime nowUtc)
    {
        var diff = utc - nowUtc;
        if (diff <= TimeSpan.Zero) return "expired";
        return $"{diff.Days}d {diff.Hours}h {diff.Minutes}m";
    }
}

@{
    var usd = CultureInfo.GetCultureInfo(DirectoryManager.Web.Constants.StringConstants.EnglishUS);
    var opt = Model.Option;
    var nowUtc = DateTime.UtcNow;

    var title = !string.IsNullOrWhiteSpace(opt.ScopeLabel)
        ? opt.ScopeLabel
        : opt.SponsorshipType.ToString();

    int? categoryId = opt.SponsorshipType == SponsorshipType.CategorySponsor ? Model.TypeId : null;
    int? subCategoryId = opt.SponsorshipType == SponsorshipType.SubcategorySponsor ? Model.TypeId : null;

    var eligible = Model.CanAdvertise;

    var poolHasCapacity =
        opt.PoolMaxSlots > 0 &&
        opt.PoolActiveCount < opt.PoolMaxSlots;

    var blockedByMainSubCap = opt.BlockedByMainSubcategoryCap;

    var availableNow = eligible && !opt.IsExtension && poolHasCapacity && !blockedByMainSubCap;

    var postStartCheckoutUrl =
        Url.Action("SelectListing", "SponsoredListing") ?? "/sponsoredlisting/selectlisting";

    var extendHref =
        Url.Action("SelectDuration", "SponsoredListing", new
        {
            directoryEntryId = Model.DirectoryEntryId,
            sponsorshipType = opt.SponsorshipType
        }) ?? "/sponsoredlisting/selectduration";

    var hasWaitlist = opt.Waitlist != null && opt.Waitlist.Count > 0;

    var waitlistUrl =
        (opt.Waitlist != null && !string.IsNullOrWhiteSpace(opt.Waitlist.BrowseUrl))
            ? opt.Waitlist.BrowseUrl
            : (Url.Action("Waitlist", "Sponsorship", new { type = opt.SponsorshipType, typeId = Model.TypeId }) ?? "");

    var nextExpire = (opt.ActiveSlots != null && opt.ActiveSlots.Any())
        ? opt.ActiveSlots.OrderBy(x => x.CampaignEndUtc).FirstOrDefault()
        : null;
}

<div class="card u-p-14px-rounded-12px">
    <div class="u-flex-justify-space-between-items-flex-start-gap-12px">
        <div>
            <h3 class="u-m-0-0-6px-0">@title</h3>

            <div class="u-opacity-9">
                @if (!eligible)
                {
                    <span><strong>Not eligible yet</strong> — you can still subscribe above.</span>
                }
                else if (opt.IsExtension)
                {
                    <span><strong>Active</strong> — you can extend anytime.</span>
                    @if (opt.YourActiveUntilUtc.HasValue)
                    {
                        <text>(</text><span class="u-opacity-85">until <strong>@FormatUtcFull(opt.YourActiveUntilUtc.Value)</strong></span><text>)</text>
                    }
                }
                else if (availableNow)
                {
                    <div class="orange-text">
                        Available now — proceed to checkout.
                    </div>
                }
                else
                {
                    if (opt.PoolMaxSlots > 0 && opt.PoolActiveCount >= opt.PoolMaxSlots)
                    {
                        <span><strong>Full right now</strong> — subscribe above to get notified.</span>
                    }
                    else
                    {
                        <span><strong>Not available right now</strong> — subscribe above to get notified.</span>
                    }
                }

                @if (opt.BlockedByMainSubcategoryCap && opt.NextOpeningForMainSubcategoryCapUtc.HasValue)
                {
                    <div class="u-mt-6px-opacity-85">
                        Main-per-subcategory cap reached. Next likely opening:
                        <strong>@FormatUtcFull(opt.NextOpeningForMainSubcategoryCapUtc.Value)</strong>
                        <span class="u-block-opacity-85">
                            in @FormatCountdown(opt.NextOpeningForMainSubcategoryCapUtc.Value, nowUtc)
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="u-text-right-minw-120px">
            <div class="u-opacity-85">
                Slots: <strong>@opt.PoolActiveCount</strong> / @opt.PoolMaxSlots
            </div>
        </div>
    </div>

    <div class="u-mt-12px-flex-gap-10px-flexwrap-wrap-items-center">
        @if (opt.IsExtension)
        {
            <a class="btn btn-info btn-cta" href="@extendHref">Extend</a>
        }
        else if (availableNow)
        {
            <form class="u-m-0" method="post" action="@postStartCheckoutUrl">
                @Html.AntiForgeryToken()

                <input type="hidden" name="sponsorshipType" value="@opt.SponsorshipType" />
                <input type="hidden" name="directoryEntryId" value="@Model.DirectoryEntryId" />

                @if (categoryId.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@categoryId.Value" />
                }
                @if (subCategoryId.HasValue)
                {
                    <input type="hidden" name="subCategoryId" value="@subCategoryId.Value" />
                }

                <button type="submit" class="btn btn-primary btn-cta">Checkout</button>
            </form>

            @if (hasWaitlist && !string.IsNullOrWhiteSpace(waitlistUrl))
            {
                <a class="btn btn-info" href="@waitlistUrl">View waitlist</a>
            }
        }
        else
        {
            @if (hasWaitlist && !string.IsNullOrWhiteSpace(waitlistUrl))
            {
                <a class="btn btn-info" href="@waitlistUrl">View waitlist</a>
            }
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.DetailsHtml))
    {
        <details class="u-mt-12px">
            <summary class="u-cursor-pointer"><strong>What’s included</strong></summary>
            <div class="u-mt-10px">
                @Html.Raw(Model.DetailsHtml)
            </div>
        </details>
    }

    @if (opt.Offers != null && opt.Offers.Any())
    {
        <div class="u-mt-14px">
            <div class="u-fw-600-mb-6px">Pricing</div>
            <div class="pricing-stack u-border-1px-solid-var-border-strong-rounded-var-radius">
                @{
                    var orderedOffers = opt.Offers.OrderBy(x => x.Days).ToList();
                    decimal? baselinePerDay = orderedOffers.Count > 0 ? orderedOffers[0].PricePerDay : (decimal?)null;
                }
                @for (var i = 0; i < orderedOffers.Count; i++)
                {
                    var o = orderedOffers[i];
                    var rowBorder = i == orderedOffers.Count - 1 ? "0" : "1px solid var(--border-divider)";

                    int? pctDiscount = null;
                    decimal? totalUsdSaved = null;
                    if (i > 0 && baselinePerDay.HasValue && baselinePerDay.Value > 0)
                    {
                        var usdDiscountPerDay = baselinePerDay.Value - o.PricePerDay;
                        pctDiscount = (int)Math.Round((usdDiscountPerDay / baselinePerDay.Value) * 100m, 0, MidpointRounding.AwayFromZero);
                        totalUsdSaved = (baselinePerDay.Value * o.Days) - o.PriceUsd;
                    }
                    <div style="display:flex; justify-content:space-between; align-items:baseline; gap:12px; padding:9px 12px; border-bottom:@rowBorder;">
                        <div class="u-ws-nowrap">
                            <span class="u-fw-600">@o.Days</span>
                            <span class="u-opacity-6"> days</span>
                            @if (i == 0)
                            {
                                <div class="u-fs-7em-opacity-5-fw-400-ls-04em-tt-uppercase-mt-2px">Market price</div>
                            }
                        </div>
                        <div class="u-text-right-lh-14-minw-0">
                            <div class="u-fw-600">@o.PriceUsd.ToString("C2", usd)</div>
                            @if (showConverted)
                            {
                                <div class="u-opacity-85-fs-9em-ws-nowrap">
                                    @DirectoryManager.Utilities.Helpers.CurrencyFormatter.Format(
                                        o.PriceUsd,
                                        conversionRate,
                                        conversionResult.selectedCurrency,
                                        true
                                    )
                                </div>
                            }
                            <div class="u-opacity-6-fs-82em-ws-nowrap">@o.PricePerDay.ToString("C2", usd)/day</div>
                            @if (totalUsdSaved.HasValue && totalUsdSaved.Value > 0 && pctDiscount.HasValue && pctDiscount.Value > 0)
                            {
                                <div class="text-danger u-fs-82em-ws-nowrap-mt-2px">
                                    @(pctDiscount)% off &middot; save @totalUsdSaved.Value.ToString("C2", usd)
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (nextExpire != null && nextExpire.CampaignEndUtc > nowUtc)
            {
                <div class="u-mt-10px-p-10px-rounded-10px-bg-rgba-255-255-255-003">
                    <div class="u-fw-600">Next expiration</div>
                    <div class="u-opacity-9-mt-4px">
                        <strong>@nextExpire.ListingName</strong>
                        <span class="u-opacity-85">—</span>
                        <strong>@FormatUtcFull(nextExpire.CampaignEndUtc)</strong>
                        <span class="u-block-opacity-85">
                            in @FormatCountdown(nextExpire.CampaignEndUtc, nowUtc)
                        </span>
                    </div>
                </div>
            }
        </div>
    }

    @if (opt.ActiveSlots != null && opt.ActiveSlots.Any())
    {
        <div class="u-mt-14px">
            <div class="u-fw-600-mb-6px">Active sponsors (next to expire)</div>
            <ul class="u-m-0-pl-18px">
                @foreach (var s in opt.ActiveSlots.OrderBy(x => x.CampaignEndUtc))
                {
                    <li>
                        @if (!string.IsNullOrWhiteSpace(s.ListingUrl))
                        {
                            <a href="@s.ListingUrl" target="_blank" rel="noopener">@s.ListingName</a>
                        }
                        else
                        {
                            @s.ListingName
                        }

                        @if (s.IsYou)
                        {
                            <span class="u-ml-6px-opacity-9"><strong>(you)</strong></span>
                        }

                        <span class="u-opacity-85">
                            — expires <strong>@FormatUtcFull(s.CampaignEndUtc)</strong>
                            @if (s.CampaignEndUtc > nowUtc)
                            {
                                <span class="u-block-opacity-85">
                                    in @FormatCountdown(s.CampaignEndUtc, nowUtc)
                                </span>
                            }
                            else
                            {
                                <span class="u-block-opacity-85">expired</span>
                            }
                        </span>
                    </li>
                }
            </ul>
        </div>
    }

    @if (hasWaitlist)
    {
        var joinRank = Math.Max(1, opt.Waitlist!.JoinWouldBeRank);

        <div class="u-mt-14px">
            <div class="u-fw-600">
                Waitlist: <strong>@opt.Waitlist!.Count</strong> waiting
                <span class="u-opacity-85">— you’d join at position <strong>#@joinRank</strong></span>
            </div>

            @if (opt.Waitlist!.Preview != null && opt.Waitlist.Preview.Any())
            {
                <ul class="u-m-8px-0-0-0-pl-18px">
                    @foreach (var w in opt.Waitlist.Preview.OrderByDescending(x => x.JoinedUtc))
                    {
                        <li>
                            @if (!string.IsNullOrWhiteSpace(w.ListingUrl))
                            {
                                <a href="@w.ListingUrl" target="_blank" rel="noopener">@w.ListingName</a>
                            }
                            else
                            {
                                @w.ListingName
                            }
                            <span class="u-opacity-85">
                                — joined @FormatUtcFull(w.JoinedUtc)
                            </span>
                        </li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(waitlistUrl))
            {
                <div class="u-mt-10px">
                    <a class="btn btn-info" href="@waitlistUrl">View waitlist</a>
                </div>
            }
        </div>
    }
</div>