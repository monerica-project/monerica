@model DirectoryManager.Web.Models.Sponsorship.SponsorshipIndexVm
@using System.Globalization
@using DirectoryManager.Data.Enums
@using DirectoryManager.DisplayFormatting.Helpers
@using DirectoryManager.Utilities.Helpers
@using DirectoryManager.Web.Constants
@using DirectoryManager.Web.Helpers
@using DirectoryManager.Common.Constants
@inject DirectoryManager.Web.Services.Interfaces.ICacheService cacheHelper
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpContextAccessor
@inject DirectoryManager.Common.Interfaces.IRateConversionService rateConversionService
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache memoryCache
@{
    ViewData[DirectoryManager.Web.Constants.StringConstants.TitleHeader] = "Join the Sponsor Waitlist";
    Layout = "_CenteredLayout";

    var q = (Model.Query ?? string.Empty).Trim();
    var usd = CultureInfo.GetCultureInfo(DirectoryManager.Web.Constants.StringConstants.EnglishUS);
}

@section PageContent {

    <div class="page-header-bar">
        <h1 class="page-title">@ViewData[DirectoryManager.Web.Constants.StringConstants.TitleHeader]</h1>
        @await Html.PartialAsync("_SiteLogo")
    </div>

    <hr />
    @await Html.PartialAsync("_BackToHome")
    <hr />

    <p class="u-m-6px-0-12px-0-fs-105rem">
        Sponsor spots are limited. Find your listing below to <strong>claim an open spot</strong> or
        <strong>join the waitlist</strong> — we'll email you the moment one opens.
        <a class="app-link" href="~/sponsors">See who's sponsoring now &amp; recent payments →</a>
    </p>

    @Html.Raw(await cacheHelper.GetSnippetAsync(SiteConfigSetting.SponsoredListingSteps))
    <p class="u-m-0-0-6px-0"><strong>How to sponsor a spot:</strong></p>
    <ol class="u-m-0-0-12px-0-pl-22px">
        <li>Your site must be listed in the directory first. <a href="~/submit">Not listed yet? Submit it →</a></li>
        <li>Search your listing below.</li>
        <li>Select it to see every placement, live prices, and which spots are open — then pay in XMR, or join the waitlist if the spot you want is taken.</li>
    </ol>
    <p class="u-m-0-0-10px-0-opacity-9">
        Every listing has up to 3 placements (Main, Category, Subcategory), each in different durations and prices.
    </p>

    <!-- SEARCH -->
    <form method="get" action="@Url.Action("Index", "Sponsorship")" class="search-form u-m-16px-0">
        <input type="search"
 name="q"
 value="@q"
 placeholder="Search listings… (name, website)"
 class="form-control u-maxw-520px-inline-block" />
        <button type="submit" class="btn btn-primary btn-cta">Find my listing</button>
    </form>
    <p class="u-m-6px-0-16px-0-opacity-85">
        Don't see your site, or not listed yet? <a href="~/submit">Submit it first →</a>
        Questions? <a href="~/contact">Contact us</a>.
    </p>

    @if (Model.HasSearched)
    {
        <h2 class="u-mt-18px">Search results</h2>

        <p class="u-m-6px-0-12px-0">
            @Model.TotalCount result@(Model.TotalCount == 1 ? "" : "s")
            @if (Model.TotalPages > 1)
            {
                <span> — page @Model.Page of @Model.TotalPages</span>
            }
        </p>

        @if (Model.Results != null && Model.Results.Any())
        {
            <div class="search-results">
                @foreach (var r in Model.Results)
                {
                    var meta = r.Status;
                    if (!string.IsNullOrWhiteSpace(r.Category)) { meta += $" · {r.Category}"; }
                    if (!string.IsNullOrWhiteSpace(r.Subcategory)) { meta += $" » {r.Subcategory}"; }
                    meta += $" · listed {r.AgeDays} days";

                    <div class="result-row u-flex-flexwrap-wrap-items-center-gap-8px-16px-p-12px-0">
                        <div class="u-flex-1-1-240px-minw-0">
                            <div class="u-fs-105em-fw-600">
                                @if (!string.IsNullOrWhiteSpace(r.Link))
                                {
                                    <a href="@r.Link" target="_blank" rel="noopener">@r.Name</a>
                                }
                                else
                                {
                                    @r.Name
                                }
                            </div>
                            <div class="u-opacity-8-fs-9em-mt-2px">@meta</div>

                            @if (!r.CanAdvertise && r.Reasons != null && r.Reasons.Any())
                            {
                                <ul class="u-m-6px-0-0-18px-opacity-85-fs-9em">
                                    @foreach (var reason in r.Reasons)
                                    {
                                        <li>@reason</li>
                                    }
                                </ul>
                            }
                        </div>

                        <form class="u-flex-0-0-auto-m-0" method="post" action="@Url.Action("Select", "Sponsorship")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="directoryEntryId" value="@r.DirectoryEntryId" />
                            <button type="submit" class="btn @(r.CanAdvertise ? "btn-info" : "btn-secondary")">
                                See available spots
                            </button>
                        </form>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="u-m-12px-0-22px-0">
                    @{
                        var prev = Model.Page > 1 ? Model.Page - 1 : (int?)null;
                        var next = Model.Page < Model.TotalPages ? Model.Page + 1 : (int?)null;
                    }
                    @if (prev.HasValue)
                    {
                        <a class="btn btn-secondary" href="@Url.Action("Index", "Sponsorship", new { q = q, page = prev.Value })">← Prev</a>
                    }
                    @if (next.HasValue)
                    {
                        <a class="btn btn-secondary u-ml-8px" href="@Url.Action("Index", "Sponsorship", new { q = q, page = next.Value })">Next →</a>
                    }
                </div>
            }
        }
        else
        {
            <p class="u-mt-8px">
                No directory listing found for <strong>@q</strong>. A site has to be listed in the
                directory before it can be sponsored — <a href="~/submit">submit it here</a>, then
                come back and search again. Questions? <a href="~/contact">Contact us</a>.
            </p>
        }
    }

    <!-- PACKAGE DETAILS -->
    <hr />

    @* MAIN SPONSOR OPEN / NEXT OPENING *@
    @if (Model.MainSponsorIsOpen)
    {
        <p class="orange-text u-m-0-0-10px-0-fw-800">
            Main Sponsor is OPEN — find your listing above and claim your spot.
        </p>
    }
    else if (Model.MainSponsorInventory != null)
    {
        <div class="adspace-full u-m-0-0-12px-0">
            <p>
                Sorry, the maximum number of <b>@EnumHelper.GetDescription(SponsorshipType.MainSponsor)</b> listings has been reached!
            </p>
            <p>
                Next opening:
                <b>@Model.MainSponsorInventory.NextListingExpiration.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat)</b>
            </p>
            <p>Come back in @Model.MainSponsorInventory.TimeUntilNextMessage</p>
            <p>Search for your listing to <b>join the waitlist!</b></p>
            <p class="u-opacity-9">Category and Subcategory spots are separate from Main — search your listing above to check those.</p>
        </div>
    }

    <details class="u-m-10px-0-18px-0">
        <summary class="u-cursor-pointer"><strong>What's included in each sponsorship package?</strong></summary>
        <div class="u-mt-12px">
            <h3 class="u-m-14px-0-6px-0">@EnumHelper.GetDescription(SponsorshipType.MainSponsor)</h3>
            @Html.Raw(await cacheHelper.GetSnippetAsync(SiteConfigSetting.MainSponsoredListingDetails))

            <h3 class="u-m-18px-0-6px-0">@EnumHelper.GetDescription(SponsorshipType.CategorySponsor)</h3>
            @Html.Raw(await cacheHelper.GetSnippetAsync(SiteConfigSetting.CategorySponsoredListingDetails))

            <h3 class="u-m-18px-0-6px-0">@EnumHelper.GetDescription(SponsorshipType.SubcategorySponsor)</h3>
            @Html.Raw(await cacheHelper.GetSnippetAsync(SiteConfigSetting.SubcategorySponsoredListingDetails))
        </div>
    </details>

    <!-- WAITLIST -->
    @if (Model.WaitlistBoard != null)
    {
        <h2>Waitlist activity</h2>

        var preview = (Model.WaitlistBoard?.MainPreview ?? new List<DirectoryManager.Web.Models.Sponsorship.WaitlistPreviewRowVm>())
            .OrderByDescending(x => x.JoinedUtc)
            .ToList();

        var shown = preview.Count;
        var total = Model.WaitlistBoard?.MainWaitlistCount ?? 0;
        var remaining = Math.Max(0, total - shown);

        <p class="u-m-6px-0-10px-0">
            Main Sponsor waitlist: <strong>@total</strong> waiting
            <span class="u-opacity-85">— newest signups shown first.</span>
        </p>

        @if (shown > 0)
        {
            <p class="u-mb-6px">
                Preview: <span class="u-opacity-85">showing @shown of @total</span>
            </p>
            <ul class="u-mt-0">
                @foreach (var row in preview)
                {
                    <li>
                        @if (!string.IsNullOrWhiteSpace(row.ListingUrl))
                        {
                            <a href="@row.ListingUrl" target="_blank" rel="noopener">@row.ListingName</a>
                        }
                        else
                        {
                            @row.ListingName
                        }
                        — joined @row.JoinedUtc.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat) (UTC)
                    </li>
                }
            </ul>

            @if (!string.IsNullOrWhiteSpace(Model.WaitlistBoard.BrowseWaitlistUrl))
            {
                <div class="u-mt-10px">
                    <a class="btn btn-info" href="@Model.WaitlistBoard.BrowseWaitlistUrl">
                        Browse waitlists@(remaining > 0 ? $" (+{remaining} more)" : "")
                    </a>
                </div>
            }
        }
        else
        {
            <p class="u-opacity-85-mt-8px">No one is waiting yet.</p>
            @if (!string.IsNullOrWhiteSpace(Model.WaitlistBoard.BrowseWaitlistUrl))
            {
                <div class="u-mt-10px">
                    <a class="btn btn-info" href="@Model.WaitlistBoard.BrowseWaitlistUrl">Browse waitlists</a>
                </div>
            }
        }
    }

    <hr />
    <p class="u-m-18px-0">
        <a class="btn btn-info btn-lg" href="~/sponsors">See current sponsors, recent payments &amp; pricing &rarr;</a>
    </p>

    <!-- RECENT PAID (social proof — businesses are paying right now) -->
    @if (Model.RecentPaid != null && Model.RecentPaid.Items != null && Model.RecentPaid.Items.Any())
    {
        <hr />
        <h2 class="u-mt-22px">Businesses are paying to advertise here</h2>
        <p class="u-m-6px-0-12px-0">
            Recent paid sponsorships. Spots are limited and demand is real &mdash; <strong>join the waitlist</strong> to claim
            yours at these rates (or higher as demand grows). <a href="~/sponsors">See all sponsors &amp; payments &rarr;</a>
        </p>

        <div class="table-wrapper">
            <table class="table u-w-100pct">
                <thead>
                    <tr>
                        <th>Paid</th>
                        <th>Sponsor</th>
                        <th>Type</th>
                        <th class="u-text-right">Days</th>
                        <th class="u-text-right">Paid (@Currency.XMR.ToString())</th>
                        <th class="u-text-right">USD</th>
                        <th class="u-text-right">Expires</th>
                        <th class="u-text-right">$/day</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentPaid.Items)
                    {
                        var isMain = item.SponsorshipTypeEnum == SponsorshipType.MainSponsor;
                        <tr style="@(isMain ? "background: rgba(255,102,0,.14); font-weight:600;" : "")">
                            <td>@item.PaidUtc.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.ListingUrl))
                                {
                                    <a href="@item.ListingUrl" target="_blank" rel="noopener">@item.ListingName</a>
                                }
                                else
                                {
                                    @item.ListingName
                                }
                            </td>
                            <td>@if (isMain) { <strong class="u-color-c25700">&#9733; @item.SponsorshipType</strong> } else { @item.SponsorshipType }</td>
                            <td class="u-text-right">@item.Days</td>
                            <td class="u-text-right">
                                @item.PaidAmount.ToString(DirectoryManager.Common.Constants.StringConstants.RoundingFormatCrypto)
                            </td>
                            <td class="u-text-right">@item.AmountUsd.ToString("C2", usd)</td>
                            <td class="u-text-right">@item.ExpiresUtc.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat4)</td>
                            <td class="u-text-right">@item.PricePerDayUsd.ToString("C2", usd)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

}