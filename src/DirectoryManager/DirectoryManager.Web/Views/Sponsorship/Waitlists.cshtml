@using DirectoryManager.Web.Constants
@using DirectoryManager.Web.Models.Sponsorship
@model SponsorshipWaitlistsOverviewVm

@{
    ViewData[StringConstants.TitleHeader] = "Waitlists";
    Layout = "_CenteredLayout";
}

@section PageContent {

    <div class="page-header-bar">
        <h1 class="page-title">@ViewData[StringConstants.TitleHeader]</h1>
        @await Html.PartialAsync("_SiteLogo")
    </div>

    <hr />
    @await Html.PartialAsync("_BackToHome")
    <hr />

    <p class="u-opacity-9">
        <strong>@Model.TotalCount</strong> total signup(s) across all waitlists
    </p>

    <div class="u-m-10px-0">
        <a class="btn btn-info" href="@Url.Action("Index", "Sponsorship")">Back to sponsorship search</a>
    </div>

    @if (Model.TotalCount <= 0)
    {
        <p>No waitlist signups yet.</p>
    }
    else
    {
        <div class="u-flex-gap-10px-flexwrap-wrap-m-10px-0">
            <a class="btn btn-info" href="#main">Main Sponsor</a>
            <a class="btn btn-info" href="#category">Category Sponsor</a>
            <a class="btn btn-info" href="#subcategory">Subcategory Sponsor</a>
        </div>

        <!-- =========================
             MAIN
        ========================== -->
        <div id="main" class="card u-p-14px-rounded-12px-mt-12px">
            <div class="u-flex-justify-space-between-gap-12px-flexwrap-wrap">
                <h2 class="u-m-0">Main Sponsor</h2>
                @if (Model.Main != null && !string.IsNullOrWhiteSpace(Model.Main.BrowseUrl))
                {
                    <a class="btn btn-info" href="@Model.Main.BrowseUrl">View main waitlist (paged)</a>
                }
            </div>

            @if (Model.Main == null || Model.Main.TotalCount <= 0)
            {
                <p class="u-opacity-85-mt-10px">No signups.</p>
            }
            else
            {
                <p class="u-opacity-9-mt-10px">
                    <strong>@Model.Main.TotalCount</strong> signup(s) — A–Z by listing
                </p>

                <div class="table-wrapper">
                    <table class="table u-w-100pct">
                        <thead>
                            <tr>
                                <th class="u-text-left">Listing</th>
                                <th class="u-text-left">Joined (UTC)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Main.Items)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(row.ListingUrl))
                                        {
                                            <a href="@row.ListingUrl" target="_blank" rel="nofollow noopener">@row.ListingName</a>
                                        }
                                        else
                                        {
                                            @row.ListingName
                                        }
                                    </td>
                                    <td>@row.JoinedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- =========================
             CATEGORY
        ========================== -->
        <div id="category" class="card u-p-14px-rounded-12px-mt-16px">
            <h2 class="u-m-0">Category Sponsor</h2>

            @if (Model.Categories == null || Model.Categories.Count == 0)
            {
                <p class="u-opacity-85-mt-10px">No category waitlists yet.</p>
            }
            else
            {
                <p class="u-opacity-9-mt-10px">
                    <strong>@Model.Categories.Sum(x => x.TotalCount)</strong> signup(s) across <strong>@Model.Categories.Count</strong> category scope(s)
                    — scopes A–Z, listings A–Z
                </p>

                @foreach (var scope in Model.Categories)
                {
                    <details class="u-mt-12px" open>
                        <summary class="u-cursor-pointer">
                            <strong>@scope.ScopeLabel</strong> — <strong>@scope.TotalCount</strong> signup(s)
                            @if (!string.IsNullOrWhiteSpace(scope.BrowseUrl))
                            {
                                <span class="u-ml-10px">
                                    <a href="@scope.BrowseUrl">paged</a>
                                </span>
                            }
                        </summary>

                        <div class="table-wrapper u-mt-10px">
                            <table class="table u-w-100pct">
                                <thead>
                                    <tr>
                                        <th class="u-text-left">Listing</th>
                                        <th class="u-text-left">Joined (UTC)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in scope.Items)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(row.ListingUrl))
                                                {
                                                    <a href="@row.ListingUrl" target="_blank" rel="nofollow noopener">@row.ListingName</a>
                                                }
                                                else
                                                {
                                                    @row.ListingName
                                                }
                                            </td>
                                            <td>@row.JoinedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </details>
                }
            }
        </div>

        <!-- =========================
             SUBCATEGORY
        ========================== -->
        <div id="subcategory" class="card u-p-14px-rounded-12px-mt-16px">
            <h2 class="u-m-0">Subcategory Sponsor</h2>

            @if (Model.Subcategories == null || Model.Subcategories.Count == 0)
            {
                <p class="u-opacity-85-mt-10px">No subcategory waitlists yet.</p>
            }
            else
            {
                <p class="u-opacity-9-mt-10px">
                    <strong>@Model.Subcategories.Sum(x => x.TotalCount)</strong> signup(s) across <strong>@Model.Subcategories.Count</strong> subcategory scope(s)
                    — scopes A–Z, listings A–Z
                </p>

                @foreach (var scope in Model.Subcategories)
                {
                    <details class="u-mt-12px" open>
                        <summary class="u-cursor-pointer">
                            <strong>@scope.ScopeLabel</strong> — <strong>@scope.TotalCount</strong> signup(s)
                            @if (!string.IsNullOrWhiteSpace(scope.BrowseUrl))
                            {
                                <span class="u-ml-10px">
                                    <a href="@scope.BrowseUrl">paged</a>
                                </span>
                            }
                        </summary>

                        <div class="table-wrapper u-mt-10px">
                            <table class="table u-w-100pct">
                                <thead>
                                    <tr>
                                        <th class="u-text-left">Listing</th>
                                        <th class="u-text-left">Joined (UTC)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in scope.Items)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(row.ListingUrl))
                                                {
                                                    <a href="@row.ListingUrl" target="_blank" rel="nofollow noopener">@row.ListingName</a>
                                                }
                                                else
                                                {
                                                    @row.ListingName
                                                }
                                            </td>
                                            <td>@row.JoinedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </details>
                }
            }
        </div>
    }
}