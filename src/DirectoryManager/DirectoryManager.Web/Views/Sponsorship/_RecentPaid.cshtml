@model DirectoryManager.Web.Models.Sponsorship.RecentPaidVm
@using System.Globalization

@{
    var usd = CultureInfo.GetCultureInfo(DirectoryManager.Web.Constants.StringConstants.EnglishUS);
}

@if (Model != null)
{
    <h2 class="u-mt-22px">Recent Paid Sponsorships</h2>
    <p class="u-m-6px-0-12px-0">
        These businesses are investing in visibility and growth — sponsorship slots move fast.
    </p>

    @if (Model.Items != null && Model.Items.Any())
    {
        <div class="table-wrapper">
        <table class="table u-w-100pct">
            <thead>
                <tr>
                    <th>Paid</th>
                    <th>Type</th>
                    <th>Listing</th>
                    <th class="u-text-right">Days</th>
                    <th class="u-text-right">Paid</th>
                    <th class="u-text-right">USD</th>
                    <th class="u-text-right">Expires</th>
                    <th class="u-text-right">USD/day</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                            <td>@item.PaidUtc.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                        <td>@item.SponsorshipType</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ListingUrl))
                            {
                                <a href="@item.ListingUrl" target="_blank" rel="noopener">@item.ListingName</a>
                            }
                            else
                            {
                                @item.ListingName
                            }
                        </td>
                        <td class="u-text-right">@item.Days</td>
                        <td class="u-text-right">
                            @item.PaidAmount.ToString("0.########") @item.PaidCurrency
                        </td>
                        <td class="u-text-right">@item.AmountUsd.ToString("C2", usd)</td>
                        <td class="u-text-right">@item.ExpiresUtc.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                        <td class="u-text-right">@item.PricePerDayUsd.ToString("C2", usd)</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
}
