﻿@using DirectoryManager.Data.Enums
@using DirectoryManager.Data.Models
@using DirectoryManager.Data.Repositories.Interfaces
@using DirectoryManager.Utilities.Helpers
@using DirectoryManager.Web.Constants
@using DirectoryManager.Web.Helpers
@using DirectoryManager.Web.Models
@using DirectoryManager.Web.Services.Interfaces
@model DirectoryManager.DisplayFormatting.Models.DirectoryEntryViewModel
@inject DirectoryManager.Web.Services.Interfaces.ICacheService cacheHelper
@inject ICategoryRepository categoryRepo
@inject ISubcategoryRepository subCatRepo
@inject DirectoryManager.Web.Services.Interfaces.IUrlResolutionService UrlResolver
@inject IUrlResolutionService Urls

@{
    ViewData[StringConstants.TitleHeader] = Model.Name;
    var categoryKey = ViewBag.CategoryKey as string;
    var subCategoryKey = ViewBag.SubCategoryKey as string;
    var categoryName = ViewBag.CategoryName as string;
    var subCategoryName = ViewBag.SubCategoryName as string;

    ViewData["CurrentCategoryKey"] = categoryKey;
    ViewData["CurrentSubCategoryKey"] = subCategoryKey;

    // ✅ scam flag
    var isScam = Model.DirectoryStatus == DirectoryStatus.Scam;

    // Determine which links to use based on the availability of "A" versions
    // NOTE: For scams, we will NOT use these for outbound website linking (we show plain text Model.Link instead)
    var finalLink = !string.IsNullOrEmpty(Model.LinkA) && !Model.IsSponsored ? Model.LinkA : Model.Link;
    var finalLink2 = !string.IsNullOrEmpty(Model.Link2A) && !Model.IsSponsored ? Model.Link2A : Model.Link2;
    var finalLink3 = !string.IsNullOrEmpty(Model.Link3A) && !Model.IsSponsored ? Model.Link3A : Model.Link3;

    // Suppress the main Website row if Link2 or Link3 is the same URL
    var mainLinkIsDuplicate =
        (!string.IsNullOrEmpty(Model.Link2) && string.Equals(Model.Link, Model.Link2, StringComparison.OrdinalIgnoreCase)) ||
        (!string.IsNullOrEmpty(Model.Link3) && string.Equals(Model.Link, Model.Link3, StringComparison.OrdinalIgnoreCase));

    // Mark as sponsored if the listing is a paid sponsor OR if the resolved link is an affiliate ("A") variant
    var isQuestionable = Model.DirectoryStatus == DirectoryStatus.Questionable;

    var finalLinkRel = string.Join(" ", new[]
    {
    isQuestionable ? "nofollow" : "",
    (Model.IsSponsored || !string.IsNullOrEmpty(Model.LinkA)) ? "sponsored" : ""
}.Where(s => !string.IsNullOrEmpty(s)));

    var finalLink2Rel = string.Join(" ", new[]
    {
    isQuestionable ? "nofollow" : "",
    (Model.IsSponsored || !string.IsNullOrEmpty(Model.Link2A)) ? "sponsored" : ""
}.Where(s => !string.IsNullOrEmpty(s)));

    var finalLink3Rel = string.Join(" ", new[]
    {
    isQuestionable ? "nofollow" : "",
    (Model.IsSponsored || !string.IsNullOrEmpty(Model.Link3A)) ? "sponsored" : ""
}.Where(s => !string.IsNullOrEmpty(s)));

    var domain = await cacheHelper.GetSnippetAsync(SiteConfigSetting.CanonicalDomain);

    // Build your breadcrumb list dynamically based on page context
    var breadcrumbs = new List<BreadcrumbItem>
    {
        new BreadcrumbItem { Position = 1, Name = "Home", Url = UrlHelper.MakeFullUrl(domain,"/") },
        new BreadcrumbItem { Position = 2, Name = @categoryName, Url = UrlHelper.MakeFullUrl(domain,$"/{@categoryKey}") },
        new BreadcrumbItem { Position = 3, Name = @subCategoryName, Url = UrlHelper.MakeFullUrl(domain,$"/{@categoryKey}/{@subCategoryKey}")  },
        new BreadcrumbItem { Position = 4, Name = Model.Name, Url = UrlHelper.MakeFullUrl(domain, UrlBuilder.ListingPath(@Model.DirectoryEntryKey))  }
    };

    var processorParts = ViewBag.ProcessorParts as List<DirectoryManager.Web.Models.ProcessorPart>;

    // Copy-and-paste "Review us on Monerica" badge for listing owners.
    // Full, self-contained HTML (inline styles + absolute logo URL) so it renders
    // correctly on any external site. Links to the listing page (not the #reviews hash).
    var listingUrl = UrlHelper.MakeFullUrl(domain, UrlBuilder.ListingPath(Model.DirectoryEntryKey));

    // The embed badge always uses the hosted CDN logo so it renders on any external site.
    var badgeLogoUrl = "https://cdn.monerica.com/directorycontent/images/monerica-logo.png";

    // Attribute-encode URLs (a CDN logo URL may contain query params) and text.
    var encodedListingUrl = System.Net.WebUtility.HtmlEncode(listingUrl);
    var encodedBadgeLogoUrl = System.Net.WebUtility.HtmlEncode(badgeLogoUrl);
    var encodedListingName = System.Net.WebUtility.HtmlEncode(Model.Name);

    var reviewBadgeSnippet =
        $"<a href=\"{encodedListingUrl}\" target=\"_blank\" rel=\"noopener\" " +
        "style=\"display:inline-flex;align-items:center;gap:10px;padding:8px 14px;" +
        "font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:bold;line-height:1.2;" +
        "color:#ffffff;background-color:#1d1d1d;border:1px solid #ff6600;border-radius:8px;" +
        "text-decoration:none;\">" +
        "<span style=\"display:inline-flex;align-items:center;background:#ffffff;" +
        "border-radius:4px;padding:3px 5px;line-height:0;\">" +
        $"<img src=\"{encodedBadgeLogoUrl}\" alt=\"{(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName))}\" height=\"18\" " +
        "style=\"height:18px;width:auto;display:block;border:0;\" /></span>" +
        $"Review {encodedListingName} on {(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName))}</a>";
}

@{
    Layout = "_LayoutWithNav";
}

@section PageContent {

    <div class="directory-entry-details container py-4">
        <h1 class="mb-3 multi-line-text">@Model.Name</h1>
        <hr />
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a class="no-app-link" href="@UrlResolver.ResolveToRoot("/")">Home</a>
                </li>
                <li class="breadcrumb-item">
                    <a class="no-app-link" href="@UrlResolver.ResolveToRoot($"/{categoryKey}")">@categoryName</a>
                </li>
                <li class="breadcrumb-item">
                    <a class="no-app-link" href="@UrlResolver.ResolveToRoot($"/{categoryKey}/{subCategoryKey}")">@subCategoryName</a>
                </li>
                <li class="breadcrumb-item" aria-current="page">
                    @Model.Name
                </li>
            </ol>
        </nav>

        @if (Model.IsSponsored && !isScam)
        {
            <div class="sponsor-status-banner" role="note">
                <span class="badge-dot" aria-hidden="true">&#9733;</span>
                <span>This listing is a <strong>@(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)) sponsor</strong>.</span>
            </div>
        }

        @{
            var sponsoredClass = Model.IsSponsored ? "sponsor-card" : "";
        }

        @* ---------------------------------------------------------------
           Meta card. Fixed-layout table inside a width-capped card so every
           profile renders at the same size no matter how long the values are.
           --------------------------------------------------------------- *@
        <div class="entry-card @(Model.IsSponsored ? "entry-card--sponsor" : "")">
            <table class="entry-meta-table">
                <colgroup>
                    <col class="entry-meta-label-col" />
                    <col class="entry-meta-value-col" />
                </colgroup>
                <tbody>
                    <tr>
                        <th scope="row">Name</th>
                        <td>
                            <span class="@sponsoredClass">@Model.Name</span>
                        </td>
                    </tr>

                    @if (!string.IsNullOrWhiteSpace(Model.Link) && !mainLinkIsDuplicate)
                    {
                        <tr>
                            <th scope="row">Website</th>
                            <td>
                                @if (isScam)
                                {
                                    <span class="multi-line-text">@Model.Link</span>
                                }
                                else
                                {
                                    <a class="multi-line-text" href="@finalLink" target="_blank" @(string.IsNullOrEmpty(finalLinkRel) ? "" : $" rel=\"{finalLinkRel}\"")>@Model.Link</a>
                                }
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(finalLink2))
                    {
                        <tr>
                            <th scope="row">@Model.Link2Name</th>
                            <td>
                                @if (isScam)
                                {
                                    <span class="multi-line-text">@Model.Link2</span>
                                }
                                else
                                {
                                    <a class="multi-line-text" href="@finalLink2" target="_blank" @(string.IsNullOrEmpty(finalLink2Rel) ? "" : $" rel=\"{finalLink2Rel}\"")>@Model.Link2</a>
                                }
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(finalLink3))
                    {
                        <tr>
                            <th scope="row">@Model.Link3Name</th>
                            <td>
                                @if (isScam)
                                {
                                    <span class="multi-line-text">@Model.Link3</span>
                                }
                                else
                                {
                                    <a class="multi-line-text" href="@finalLink3" target="_blank" @(string.IsNullOrEmpty(finalLink3Rel) ? "" : $" rel=\"{finalLink3Rel}\"")>@Model.Link3</a>
                                }
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.ProofLink) &&
                         !string.Equals(Model.ProofLink.TrimEnd('/'), Model.Link?.TrimEnd('/'), StringComparison.OrdinalIgnoreCase))
                    {
                        <tr>
                            <th scope="row">Proof</th>
                            <td>
                                @if (isScam)
                                {
                                    <span class="multi-line-text">@Model.ProofLink</span>
                                }
                                else
                                {
                                    <a class="multi-line-text" href="@Model.ProofLink" target="_blank">@Model.ProofLink</a>
                                }
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.VideoLink))
                    {
                        <tr>
                            <th scope="row">Video</th>
                            <td>
                                @if (isScam)
                                {
                                    <span class="multi-line-text">@Model.VideoLink</span>
                                }
                                else
                                {
                                    <a class="multi-line-text" href="@Model.VideoLink" target="_blank">@Model.VideoLink</a>
                                }
                            </td>
                        </tr>
                    }

                    <tr>
                        <th scope="row">Status</th>
                        <td>@Model.DirectoryStatus.ToHtmlIcon() @Model.DirectoryStatus</td>
                    </tr>


                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <tr>
                            <th scope="row">Email</th>
                            <td>
                                @Html.Raw(StringHelpers.RenderContactFieldHtml(Model.Email, cssClass: "multi-line-text"))
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.Messenger))
                    {
                        <tr>
                            <th scope="row">Messenger</th>
                            <td>
                                @Html.Raw(StringHelpers.RenderContactFieldHtml(Model.Messenger, cssClass: "multi-line-text"))
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.Social))
                    {
                        <tr>
                            <th scope="row">Social</th>
                            <td>
                                @Html.Raw(StringHelpers.RenderContactFieldHtml(Model.Social, cssClass: "multi-line-text"))
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.Location) || !string.IsNullOrWhiteSpace(Model.CountryCode))
                    {
                        <tr>
                            <th scope="row">Location</th>
                            <td>
                                @Html.Raw(Model.FormattedLocation)
                            </td>
                        </tr>
                    }

                    @if (!string.IsNullOrEmpty(Model.Processor))
                    {
                        <tr>
                            <th scope="row">Processor</th>
                            <td>
                                @if (processorParts != null && processorParts.Count > 0)
                                {
                                    for (int i = 0; i < processorParts.Count; i++)
                                    {
                                        var p = processorParts[i];

                                        if (!string.IsNullOrEmpty(p.EntryKey))
                                        {
                                            <a class="no-app-link" href="@UrlResolver.ResolveToRoot(UrlBuilder.ListingPath(p.EntryKey))">@p.Display</a>
                                        }
                                        else
                                        {
                                            @p.Display
                                        }

                                        if (i < processorParts.Count - 1)
                                        {
                                            @:, 
                                        }
                                    }
                                }
                                else
                                {
                                    @Model.Processor
                                }
                            </td>
                        </tr>
                    }

                    @if (Model.FoundedDate.HasValue)
                    {
                        <tr>
                            <th scope="row">Founded</th>
                            <td>@Model.FoundedDate.Value.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                        </tr>
                    }

                    <tr>
                        <th scope="row">Added On</th>
                        <td>@Model.CreateDate.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                    </tr>

                    @if (Model.UpdateDate.HasValue)
                    {
                        <tr>
                            <th scope="row">Last Updated</th>
                            <td>@Model.UpdateDate.Value.ToString(DirectoryManager.Common.Constants.StringConstants.DateFormat)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ✅ Button removed for scams *@
        @if (!isScam && !string.IsNullOrWhiteSpace(finalLink))
        {
            <div class="entry-cta">
                <a href="@finalLink" class="btn btn-primary btn-cta entry-cta-btn" target="_blank" @(string.IsNullOrEmpty(finalLinkRel) ? "" : $" rel=\"{finalLinkRel}\"")>Visit Website</a>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="entry-section">
                <h3>Description</h3>
                <p class="mb-0">@Model.Description</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="entry-section multi-line-text">
                @if (Model.DirectoryStatus == DirectoryStatus.Scam || Model.DirectoryStatus == DirectoryStatus.Questionable)
                {
                    <h4 class="warning-color">Note</h4>
                }
                else
                {
                    <h4>Note</h4>
                }
                <p class="mb-0"><em>@Html.Raw(ContentSanitizer.Sanitize(Model.Note))</em></p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.PgpKey))
        {   <br />
            <div class="entry-section">
                <h4>PGP Key</h4>
<pre class="pgp-key">
@Model.PgpKey
</pre>
            </div>
        }

        @if (Model.TagsAndKeys?.Any() ?? false)
        {
            <br />
            <div class="entry-section entry-tags">
                <strong>Tags:</strong>
                @{
                    // materialize to list so we can test "last" easily
                    var tags = Model.TagsAndKeys.ToList();
                }
                @for (int i = 0; i < tags.Count; i++)
                {
                    var key = tags[i].Key;     // slug / url-key
                    var name = tags[i].Value;  // display name

                    <a class="no-app-link" href="~/tagged/@key">@name</a>@(i < tags.Count - 1 ? ", " : "")
                }
            </div>
        }

        @if (Model.AdditionalLinks?.Any() ?? false)
        {
            <div class="entry-section entry-additional-links">
                <strong>Related Links:</strong>
                <ul class="mb-0">
                    @foreach (var link in Model.AdditionalLinks)
                    {
                        <li>
                            <a class="multi-line-text" href="@link" target="_blank" rel="nofollow noopener">@link</a>
                        </li>
                    }
                </ul>
            </div>
        }

        <div class="entry-section">
            @await Html.PartialAsync("_EntryReviews", (DirectoryManager.Web.Models.Reviews.EntryReviewsBlockViewModel)ViewBag.ReviewsVm)
        </div>

        @* ---------------------------------------------------------------
           "Review us on Monerica" embed badge. Listing owners copy this HTML
           onto their own site to send visitors here to leave a review.
           Hidden for scam listings, AND hidden when reviews are turned off
           (no point inviting reviews when the review system is closed).
           --------------------------------------------------------------- *@
        @{
            var reviewsVmForEmbed = ViewBag.ReviewsVm as DirectoryManager.Web.Models.Reviews.EntryReviewsBlockViewModel;
            var reviewsDisabled = reviewsVmForEmbed?.ReviewsDisabled ?? false;
        }
        @if (!isScam && !reviewsDisabled)
        {
            <div class="entry-section entry-embed">
                <h3>Get more reviews</h3>
                <p class="mb-2">
                    Add this badge to your own website to invite visitors to review
                    <strong>@Model.Name</strong> on @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)). Click inside the box below,
                    select all (Ctrl&#8209;A / &#8984;A), copy (Ctrl&#8209;C / &#8984;C), and
                    paste the HTML anywhere on your site.
                </p>

                <div class="entry-embed-preview u-mb-075rem">
                    <span class="u-block-fs-085rem-opacity-075-mb-035rem">Preview:</span>
                    @Html.Raw(reviewBadgeSnippet)
                </div>

                <textarea class="u-w-100pct-box-border-box-ff-monospace-fs-13px-color-ffffff" rows="4" readonly aria-label="Review badge embed code">@reviewBadgeSnippet</textarea>
            </div>
        }

        @* ---------------------------------------------------------------
           Sponsorship options call-to-action. Shown near the bottom of
           every eligible profile. Scam AND questionable listings are NOT
           eligible to sponsor, so the section is hidden for them.
           Links to /sponsorship/options/{id}.
           --------------------------------------------------------------- *@
        @if (!isScam && !isQuestionable)
        {
            <div class="sponsor-cta">
                @if (Model.IsSponsored)
                {
                    <h3>&#9733; @Model.Name is a @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)) sponsor</h3>
                    <p>Thanks for supporting @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)). You can review or extend your sponsorship below.</p>
                    <a class="btn-sponsor"
                       href="@UrlResolver.ResolveToApp($"/sponsorship/options/{Model.DirectoryEntryId}")">
                        Manage sponsorship options
                    </a>
                }
                else
                {
                    <h3>Sponsor this listing</h3>
                    <p>Boost @Model.Name to the top of its category and across @(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.SiteName)).</p>
                    <a class="btn-sponsor"
                       href="@UrlResolver.ResolveToApp($"/sponsorship/options/{Model.DirectoryEntryId}")">
                        View sponsorship options
                    </a>
                }
            </div>
        }

        @* ---------------------------------------------------------------
           Change history + suggest-an-edit links. History is public for
           every listing (transparency); the edit form is captcha-gated.
           --------------------------------------------------------------- *@
        <p class="entry-edit-link">
            <a rel="nofollow"
               href="@UrlResolver.ResolveToApp($"/history/{Model.DirectoryEntryId}")">
                View change history
            </a>
            @if (!isScam)
            {
                <span class="listing-history-sep">&middot;</span>
                <span>See something out of date?</span>
                <a rel="nofollow"
                   href="@UrlResolver.ResolveToApp($"/submission/submitedit/{Model.DirectoryEntryId}")">
                    Submit a revision
                </a>
            }
        </p>

    </div>

    <hr />
    @await Html.PartialAsync("_SponsoredListingPartial")
}