@model DirectoryManager.Web.Models.LoginViewModel
@using DirectoryManager.Web.Constants;

@{
    ViewData[StringConstants.TitleHeader] = "Admin home";
    Layout = "_CenteredLayout";
}

@functions {
    // Smallest-unit compact relative time: 45m / 3h / 2d.
    // Only one unit is shown, whichever is the current "bucket".
    static string FormatAgoCompact(DateTime? utc)
    {
        if (!utc.HasValue)
        {
            return string.Empty;
        }

        var diff = DateTime.UtcNow - utc.Value;
        if (diff.TotalSeconds < 60)
        {
            return "just now";
        }

        if (diff.TotalMinutes < 60)
        {
            return $"{(int)diff.TotalMinutes}m ago";
        }

        if (diff.TotalHours < 24)
        {
            return $"{(int)diff.TotalHours}h ago";
        }

        return $"{(int)diff.TotalDays}d ago";
    }
}

