@using DirectoryManager.Web.Models
@using DirectoryManager.Data.Enums
@model EditDirectoryEntryReviewAdminViewModel
@{
    ViewData["Title"] = "Edit Review";
    Layout = "_CenteredLayout";
}

@section PageContent {
 
    <div class="container py-4">
        <h1 class="mb-3">Edit Review</h1>
        <hr />
        @await Html.PartialAsync("_AdminMenu")
        <form asp-action="Edit" asp-route-id="@Model.DirectoryEntryReviewId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DirectoryEntryReviewId" />

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="card">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="DirectoryEntryId" class="form-label"></label>
                            <input asp-for="DirectoryEntryId" class="form-control" />
                            <span asp-validation-for="DirectoryEntryId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Rating" class="form-label"></label>
                            <input asp-for="Rating" class="form-control" />
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Body" class="form-label"></label>
                            <textarea asp-for="Body" rows="8" class="form-control"></textarea>
                            <span asp-validation-for="Body" class="text-danger"></span>
                        </div>

                        <!-- ✅ Single order proof textbox -->
                        <div class="col-12">
                            <label asp-for="OrderProof" class="form-label">Order Proof (optional)</label>
                            <input asp-for="OrderProof" class="form-control" maxlength="2048" />
                            <span asp-validation-for="OrderProof" class="text-danger"></span>
                            <div class="form-text">Paste either an order ID or an order URL.</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="OrderProofContext" class="form-label">Verification Details (optional)</label>
                            <textarea asp-for="OrderProofContext" class="form-control" maxlength="2048" rows="3"></textarea>
                            <span asp-validation-for="OrderProofContext" class="text-danger"></span>
                            <div class="form-text">Reviewer-supplied context (e.g. receiving wallet address). Internal only.</div>
                        </div>

                        <!-- ✅ Official review -->
                        <div class="col-12">
                            <div class="border rounded p-3">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsOfficial" />
                                    <label class="form-check-label fw-bold" asp-for="IsOfficial"></label>
                                </div>
                                <div class="form-text mb-3">
                                    Pins this review above all user reviews and badges it as official.
                                    Put the full detail in the review body above.
                                </div>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="TestedAt" class="form-label"></label>
                                        <input asp-for="TestedAt" type="date" class="form-control"
                                               value="@(Model.TestedAt?.ToString("yyyy-MM-dd"))" />
                                        <div class="form-text">Year-month-day, interpreted as UTC.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="ImageUrl" class="form-label"></label>
                                        <input asp-for="ImageUrl" class="form-control" maxlength="2048" />
                                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                        <div class="form-text">Optional link to a screenshot or other proof image.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="SendingTxUrl" class="form-label"></label>
                                        <input asp-for="SendingTxUrl" class="form-control" maxlength="2048" />
                                        <span asp-validation-for="SendingTxUrl" class="text-danger"></span>
                                        <div class="form-text">Optional explorer link for the coins you sent.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="ReceivingTxUrl" class="form-label"></label>
                                        <input asp-for="ReceivingTxUrl" class="form-control" maxlength="2048" />
                                        <span asp-validation-for="ReceivingTxUrl" class="text-danger"></span>
                                        <div class="form-text">Optional explorer link for the coins you received.</div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-text">
                                            The <strong>Order URL</strong> shown on the review is taken from the
                                            <strong>Order Proof</strong> field above — paste the exchange's order/tracking
                                            link there.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ModerationStatus" class="form-label"></label>
                            <select asp-for="ModerationStatus"
                                    class="form-select"
                                    asp-items="Html.GetEnumSelectList<ReviewModerationStatus>()"></select>
                        </div>

                        <div class="col-12">
                            <label asp-for="RejectionReason" class="form-label"></label>
                            <textarea asp-for="RejectionReason" rows="3" class="form-control"></textarea>
                        </div>

                        <!-- Tags -->
                        <div class="col-12">
                            <label class="form-label">Tags</label>
                            <div class="border rounded p-2">
                                @if (Model.AllTags == null || Model.AllTags.Count == 0)
                                {
                                    <div class="text-muted">No tags exist yet.</div>
                                }
                                else
                                {
                                    foreach (var tag in Model.AllTags)
                                    {
                                        var isChecked = Model.SelectedTagIds != null && Model.SelectedTagIds.Contains(tag.Id);
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="SelectedTagIds"
                                                   value="@tag.Id"
                                                   @(isChecked ? "checked" : "")
                                                   @(tag.IsEnabled ? "" : "disabled") />
                                            <label class="form-check-label">
                                                @tag.Name @(tag.IsEnabled ? "" : "(disabled)")
                                            </label>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="form-text">
                                Manage tags in <a href="/review-tags">Review Tags</a>.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>

        <hr />
        @await Html.PartialAsync("_SponsoredListingPartial")
    </div>
}
