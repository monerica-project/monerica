@using DirectoryManager.Data.Models.Reviews
@using DirectoryManager.Web.Constants
@using DirectoryManager.Data.Enums
@using DirectoryManager.Utilities.Helpers
@model DirectoryManager.Web.Models.Reviews.EntryReviewsModerationViewModel

@{
    Layout = "_CenteredLayout";

    var status = Model.Status;
    var heading = string.IsNullOrWhiteSpace(Model.DirectoryEntryName)
        ? $"Reviews for Entry #{Model.DirectoryEntryId}"
        : $"Reviews for {Model.DirectoryEntryName}";
    ViewData[StringConstants.TitleHeader] = heading;
}

@section PageContent {

    <h1>@ViewData[StringConstants.TitleHeader]</h1>

    @await Html.PartialAsync("_AdminMenu")

    <p class="mb-2">
        <a href="@Url.Action("Edit", "DirectoryEntry", new { id = Model.DirectoryEntryId })">&laquo; Back to Edit Entry</a>
        @if (!string.IsNullOrWhiteSpace(Model.DirectoryEntryKey))
        {
            @: |
            <a href="@UrlBuilder.ListingPath(Model.DirectoryEntryKey)" target="_blank">View Listing</a>
        }
    </p>

    <p class="mb-3">
        <a asp-action="ByEntry" asp-route-entryId="@Model.DirectoryEntryId" asp-route-status="Pending">Pending</a> |
        <a asp-action="ByEntry" asp-route-entryId="@Model.DirectoryEntryId" asp-route-status="Approved">Approved</a> |
        <a asp-action="ByEntry" asp-route-entryId="@Model.DirectoryEntryId" asp-route-status="Rejected">Rejected</a> |
        <a asp-action="ByEntry" asp-route-entryId="@Model.DirectoryEntryId">All</a>
    </p>

    <hr class="my-4" />

    <p class="text-muted">Total: @Model.Total</p>

    @if (!Model.Reviews.Any())
    {
        <p><i>No reviews found@(status.HasValue ? $" with status {status}" : string.Empty).</i></p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Status</th>
                        <th>Rating</th>
                        <th>Title</th>
                        <th>Order Proof</th>
                        <th>Created (UTC)</th>
                        <th>Fingerprint</th>
                        <th>Excerpt</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Reviews)
                    {
                        var proof = r.OrderUrl ?? r.OrderId;

                        <tr>
                            <td>
                                <a asp-action="Show" asp-route-id="@r.DirectoryEntryReviewId">@r.DirectoryEntryReviewId</a>
                            </td>
                            <td>@r.ModerationStatus</td>
                            <td>@(r.Rating?.ToString() ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(r.Title) ? "-" : r.Title)</td>

                            <td>
                                @if (string.IsNullOrWhiteSpace(proof))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(r.OrderUrl))
                                {
                                    <a href="@r.OrderUrl" target="_blank" rel="noopener">@r.OrderUrl</a>
                                }
                                else
                                {
                                    @r.OrderId
                                }
                            </td>

                            <td>@r.CreateDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><code>@r.AuthorFingerprint</code></td>
                            <td>@(string.IsNullOrWhiteSpace(r.Body) ? "-" : (r.Body.Length > 80 ? r.Body[..80] + "…" : r.Body))</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@r.DirectoryEntryReviewId">Edit</a>
                                <a asp-action="Show" asp-route-id="@r.DirectoryEntryReviewId" class="ms-1">View</a>

                                @if (r.ModerationStatus != ReviewModerationStatus.Approved)
                                {
                                    <form asp-action="Approve"
                                          asp-route-id="@r.DirectoryEntryReviewId"
                                          method="post"
                                          class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit">Approve</button>
                                    </form>
                                }

                                <a asp-action="Show"
                                   asp-route-id="@r.DirectoryEntryReviewId"
                                   class="ms-1">Reject/Delete…</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <span>Page @Model.Page of @Model.LastPage (@Model.Total total)</span>
            <div>
                @if (Model.Page > 1)
                {
                    <a asp-action="ByEntry"
                       asp-route-entryId="@Model.DirectoryEntryId"
                       asp-route-status="@(status?.ToString())"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize">Prev</a>
                    @: |
                }
                @if (Model.Page < Model.LastPage)
                {
                    <a asp-action="ByEntry"
                       asp-route-entryId="@Model.DirectoryEntryId"
                       asp-route-status="@(status?.ToString())"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize">Next</a>
                }
            </div>
        </div>
    }
}
