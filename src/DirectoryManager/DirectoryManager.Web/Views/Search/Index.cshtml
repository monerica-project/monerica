@using DirectoryManager.DisplayFormatting.Helpers
    @using DirectoryManager.Web.Constants
    @using DirectoryManager.Web.Models
    @using DirectoryManager.Web.Services.Interfaces
    @inject DirectoryManager.Web.Services.Interfaces.ICacheService cacheService
    @inject IUrlResolutionService urlService
    @model SearchViewModel
    @{
        bool hasAnyContent = Model.Entries.Any() || Model.ShowDonatePin;
        if (!hasAnyContent)
        {
            ViewData[StringConstants.TitleHeader] = "No results found.";
        }
        else
        {
            ViewData[StringConstants.TitleHeader] = $"Search results for \"{Model.Query}\"";
        }
        Layout = "_CenteredLayout";
        var q = Model.Query ?? string.Empty;
        var encodedQ = System.Net.WebUtility.UrlEncode(q);
    }
    @section PageContent {
        <div class="page-header-bar">
            <h1 class="page-title">@ViewData[StringConstants.TitleHeader]</h1>
            @await Html.PartialAsync("_SiteLogo")
        </div>
        <hr />
        @await Html.PartialAsync("_BackToHome") | <a href="~/filter">filter</a>
        <hr />
        <div class="u-text-center">
            <form method="get" class="search-form mb-3" action="">
                <input type="search"
                       maxlength="50"
                       name="q"
                       class="form-control input-width"
                       placeholder="Search…"
                       autocomplete="off"
                       aria-label="Search directory" />
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="btn btn-primary search-btn btn-cta">Search</button>
            </form>
        </div>
        @if (!hasAnyContent)
        {
            <p>No results found.</p>
        }
        else
        {
            @if (Model.Entries.Any())
            {
                <p><i>Showing @Model.Entries.Count of @Model.TotalCount results.</i></p>
            }
            <ul class="search-results">
                @if (Model.ShowDonatePin)
                {
                    <li class="search-result-pinned">
                        <span class="u-color-red">&#10084;&#65039;</span>  <a href="@urlService.BaseUrl/donate"><strong>Donate To Monerica</strong></a>
                    </li>
                }
                @foreach (var e in Model.Entries)
                {
                    @Html.Raw(DisplayMarkUpHelper.GenerateSearchResultHtml(e, urlService.BaseUrl))
                }
            </ul>
            @if (Model.Entries.Any())
            {
                int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
                int cur = Model.Page;
                // Windowed pager: at most ~10 numbered buttons + First/Prev/Next/Last.
                const int window = 9;
                int half = window / 2;
                int winStart = Math.Max(1, cur - half);
                int winEnd = Math.Min(totalPages, winStart + window - 1);
                winStart = Math.Max(1, winEnd - window + 1);
                Func<int, string> pageUrl = p => $"?q={encodedQ}&page={p}";

                if (totalPages > 1)
                {
                    <nav aria-label="Search pagination">
                        <ul class="pagination">
                            <li class="page-item @(cur <= 1 ? "disabled" : "")">
                                <a class="page-link" href="@pageUrl(1)" aria-label="First">&laquo;</a>
                            </li>
                            <li class="page-item @(cur <= 1 ? "disabled" : "")">
                                <a class="page-link" href="@pageUrl(Math.Max(1, cur - 1))" aria-label="Previous">&lsaquo;</a>
                            </li>
                            @if (winStart > 1)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                            @for (int p = winStart; p <= winEnd; p++)
                            {
                                <li class="page-item @(p == cur ? "active" : "")">
                                    <a class="page-link" href="@pageUrl(p)">@p</a>
                                </li>
                            }
                            @if (winEnd < totalPages)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                            <li class="page-item @(cur >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="@pageUrl(Math.Min(totalPages, cur + 1))" aria-label="Next">&rsaquo;</a>
                            </li>
                            <li class="page-item @(cur >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="@pageUrl(totalPages)" aria-label="Last">&raquo;</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        }
        <hr />
        @await Html.PartialAsync("_SponsoredListingPartial")
    }