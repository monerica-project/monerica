@using DirectoryManager.Web.Constants
@inject DirectoryManager.Web.Services.Interfaces.ICacheService cacheHelper
@{
    ViewData[StringConstants.MetaContent] = StringConstants.MetaTagNoIndex;
    ViewData[StringConstants.TitleHeader] = "Verification Request Received";
    Layout = "_CenteredLayout";
}

@section PageContent {
    <div class="page-header-bar">
        <h1 class="page-title">@ViewData[StringConstants.TitleHeader]</h1>
        @await Html.PartialAsync("_SiteLogo")
    </div>
    <hr />

    <p><b>Thank you for requesting a verification — your message was received.</b></p>
    <p>We review requests manually and prioritize by demand. If you'd like to support the work, a donation is appreciated:</p>

    @Html.Raw(await cacheHelper.GetSnippetAsync(DirectoryManager.Data.Enums.SiteConfigSetting.DonationHtml))

    @await Html.PartialAsync("_BackToHome")
}
