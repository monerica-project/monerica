{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "TrafficLogging": {
      "LogIpAddresses": false
    }
  },

  "Serilog": {
    "MinimumLevel": "Error",
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "",
          "tableName": "LogEntries",
          "autoCreateSqlTable": false
        }
      }
    ]
  },

  "ConnectionStrings": {
    "DefaultConnection": "",
    "AzureStorage": ""
  },
  "ApplicationSettings": {
    "TorPort": 8888
  },
  "SendGrid": {
    "ApiKey": "",
    "SenderEmail": "",
    "SenderName": ""
  }
}